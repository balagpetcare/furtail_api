{
  "name": "furtail_api",
  "version": "10.0.0.6",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "prepare": "node -e \"const {existsSync}=require('fs');if(!existsSync('.git'))process.exit(0);try{require('child_process').execSync('husky',{stdio:'inherit',env:process.env,shell:true})}catch(e){process.exit(0)}\"",
    "postinstall": "node scripts/run-local-prisma.cjs generate",
    "prebuild": "node scripts/run-local-prisma.cjs generate",
    "start": "cross-env PORT=7200 node dist/index.js",
    "dev": "cross-env PORT=7200 NODE_OPTIONS=--no-deprecation TS_NODE_TRANSPILE_ONLY=1 nodemon --watch src --ext ts,json --exec \"node -r ts-node/register src/index.ts\"",
    "prisma:generate": "node scripts/run-local-prisma.cjs generate",
    "prisma:migrate": "node scripts/run-local-prisma.cjs migrate deploy",
    "prisma:migrate:deploy": "node scripts/run-local-prisma.cjs migrate deploy",
    "prisma:migrate:dev": "node scripts/run-local-prisma.cjs migrate dev",
    "prisma:migrate:status": "node scripts/run-local-prisma.cjs migrate status",
    "prisma:version": "node scripts/run-local-prisma.cjs --version",
    "setup:prisma": "node scripts/run-local-prisma.cjs validate && node scripts/run-local-prisma.cjs generate",
    "seed": "node scripts/run-local-prisma.cjs db seed",
    "seed:prod": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/seeders/production/index.ts",
    "seed:core": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/seeders/production/index.ts",
    "seed:locations": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/seed-locations-only.ts",
    "db:reset": "node scripts/run-local-prisma.cjs migrate reset --force",
    "db:seed": "node scripts/run-local-prisma.cjs db seed",
    "admin:bootstrap": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/bootstrap-super-admin.ts",
    "create:super-admin": "npm run admin:bootstrap",
    "bootstrap:admin": "npm run admin:bootstrap",
    "admin:verify": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/verify-super-admin.ts",
    "db:deploy": "node scripts/run-local-prisma.cjs migrate deploy && node scripts/run-local-prisma.cjs db seed",
    "bootstrap:dev": "npm run setup:prisma && node scripts/run-local-prisma.cjs migrate dev",
    "bootstrap:deploy": "npm run setup:prisma && node scripts/run-local-prisma.cjs migrate deploy",
    "minio:init": "node -r ts-node/register scripts/init-minio.ts",
    "storage:init": "node -r ts-node/register scripts/init-minio.ts",
    "storage:test-upload": "node scripts/test-minio-upload.mjs",
    "storage:test": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/test-storage.ts",
    "verify:adoption-media-upload": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/verify-adoption-media-upload.ts",
    "generate:bd-pet-csv": "npx ts-node scripts/generate-bd-pet-master-csv.ts",
    "seed:location-master": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/seed-location-master.ts",
    "seed:dhaka-city": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/seed-dhaka-city.ts",
    "seed:dhaka-metro": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/seed-dhaka-metro.ts",
    "seed:coverage-zones": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/seed-coverage-zones.ts",
    "bootstrap:campaign-branch": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/bootstrap-campaign-branch.ts",
    "verify:campaign-checkout-anchor": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/verify-campaign-checkout-anchor.ts",
    "verify:location-master": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/verify-location-master.ts",
    "verify:coverage-zones": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/verify-coverage-zones.ts",
    "migrate:location-references": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/migrate-location-references.ts",
    "cleanup:categories": "npx ts-node scripts/cleanup-incorrect-categories.ts",
    "build": "rimraf dist && tsc -p tsconfig.json && node scripts/copy-runtime-assets.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:check": "node scripts/run-local-prisma.cjs validate && node scripts/run-local-prisma.cjs generate && node scripts/run-local-prisma.cjs format",
    "migrate:check-files": "node scripts/check-migration-files.js",
    "migrate:audit-deps": "node scripts/audit-migration-dependencies.mjs",
    "migrate:rollback-sim": "node scripts/migration-rollback-simulation.mjs",
    "verify": "npm run migrate:check-files && npm run prisma:check && npm run typecheck",
    "conflict:check": "node scripts/conflict-check.js",
    "test": "jest --config jest.config.js",
    "test:flow": "cross-env NODE_OPTIONS=--max-old-space-size=8192 jest --config jest.flow.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "simulate:flow": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/simulateStockFlow.ts",
    "audit:flow": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/auditStockFlow.ts",
    "repair:stock-flow": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/repairStockFlowData.ts",
    "migrate:branch-access": "node scripts/run-local-prisma.cjs generate && node scripts/run-local-prisma.cjs migrate deploy && npx ts-node scripts/backfill-branch-access-permissions.ts",
    "backfill:branch-access": "npx ts-node scripts/backfill-branch-access-permissions.ts",
    "worker:notifications": "node -r ts-node/register src/common/jobs/notificationWorker.ts",
    "worker:email": "node -r ts-node/register src/common/queue/workers/email.worker.ts",
    "worker:media": "node -r ts-node/register src/common/jobs/mediaWorker.ts",
    "media:requeue": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/requeue-unprocessed-videos.ts",
    "job:owners-automation": "node -r ts-node/register -e \"require('./src/common/jobs/ownersTeamAutomation.job').runOwnersTeamAutomationOnce().then(()=>process.exit(0)).catch(e=>{console.error(e);process.exit(1)})\"",
    "job:ai-forecast": "node -r ts-node/register -e \"require('./src/common/jobs/aiForecast.job').runAiForecastDailyJob().then(r=>{console.log(r);process.exit(r.success?0:1)}).catch(e=>{console.error(e);process.exit(1)})\"",
    "job:ai-replenishment": "node -r ts-node/register -e \"require('./src/common/jobs/aiReplenishment.job').runAiReplenishmentHourlyJob().then(r=>{console.log(r);process.exit(r.success?0:1)}).catch(e=>{console.error(e);process.exit(1)})\"",
    "job:ai-procurement-sync": "node -r ts-node/register -e \"require('./src/common/jobs/aiProcurementSync.job').runAiProcurementSyncJob().then(r=>{console.log(r);process.exit(r.success?0:1)}).catch(e=>{console.error(e);process.exit(1)})\"",
    "job:wave4-rollup": "node -r ts-node/register -e \"const oid=Number(process.env.ORG_ID||0);const d=Number(process.env.WINDOW_DAYS||30);require('./src/common/jobs/wave4Rollup.job').runWave4RollupForOrg(oid,d).then(r=>{console.log(r);process.exit(r.success?0:1)}).catch(e=>{console.error(e);process.exit(1)})\"",
    "test:invite-roles": "npx ts-node src/api/v1/constants/branchRoleMatrix.test.ts",
    "verify:clone-auth": "npx ts-node scripts/verify-clone-auth.ts",
    "validate:env": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/validate-env.ts",
    "test:eps-connection": "cross-env TS_NODE_TRANSPILE_ONLY=1 npx ts-node scripts/test-eps-connection.ts",
    "dev:infra": "docker compose up -d bpa_db furtail-redis furtail-storage",
    "dev:api": "npm run dev",
    "dev:full": "docker compose up",
    "dev:down": "docker compose down",
    "dev:down:all": "docker compose down -v --rmi all",
    "dev:down:volumes": "docker compose down -v",
    "dev:down:rmi": "docker compose down -v --rmi",
    "dev:down:volumes:rmi": "docker compose down -v --rmi all",
    "dev:down:volumes:rmi:all": "docker compose down -v --rmi all",
    "dev:down:volumes:rmi:all:volumes": "docker compose down -v --rmi all",
    "dev:down:volumes:rmi:all:volumes:all": "docker compose down -v --rmi all",
    "check:migrations": "node scripts/check-migration-collisions.js",
    "verify:warehouse-enterprise-db": "node scripts/verify-warehouse-tables.mjs",
    "clean:modules": "rimraf node_modules",
    "smoke:governance": "npx ts-node scripts/governance_smoke.ts",
    "migrate:prescription-write-overrides": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/migrate-prescription-write-overrides.ts",
    "diagnose:prescription-write-overrides": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register scripts/diagnose-prescription-write-overrides.ts",
    "seeder:dummy:users": "node -r dotenv/config -r ts-node/register scripts/seeders/dummy/index.ts --users",
    "seeder:dummy:pets": "node -r dotenv/config -r ts-node/register scripts/seeders/dummy/index.ts --pets",
    "seeder:dummy:posts": "node -r dotenv/config -r ts-node/register scripts/seeders/dummy/index.ts --posts",
    "seeder:dummy:videos": "node -r dotenv/config -r ts-node/register scripts/seeders/dummy/index.ts --videos",
    "seeder:dummy:reels": "node -r dotenv/config -r ts-node/register scripts/seeders/dummy/index.ts --reels",
    "seeder:dummy:all": "node -r dotenv/config -r ts-node/register scripts/seeders/dummy/index.ts --all",
    "seeder:dummy:clear": "node -r dotenv/config -r ts-node/register scripts/seeders/dummy/index.ts --clear"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.971.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.67.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-list-endpoints": "^6.0.0",
    "express-rate-limit": "^7.4.1",
    "ffmpeg-static": "^5.2.0",
    "firebase-admin": "^13.0.2",
    "fluent-ffmpeg": "^2.1.3",
    "google-auth-library": "^9.14.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "otplib": "^12.0.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "qrcode": "^1.5.4",
    "react-easy-crop": "^5.5.6",
    "rimraf": "^6.0.1",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "typescript": "5.9.3",
    "ws": "^8.19.0",
    "zod": "^4.3.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,prisma}": [
      "npm run conflict:check"
    ]
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/jest": "^29.5.14",
    "cross-env": "^7.0.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "nodemon": "^3.1.7",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  },
  "prisma": {
    "seed": "node -r ts-node/register prisma/seed.ts"
  }
}
