# =============================================================================
# BPA Backend API — Environment Template
# Copy to .env and fill in values. Never commit real secrets.
# Validate: npm run validate:env
# Docs: docs/environment/LOCAL_SETUP_GUIDE.md
# =============================================================================

# --- Server (fixed port: 3000) ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1
API_VERSION=v1

# --- Database (required) ---
DATABASE_URL=
SHADOW_DATABASE_URL=

# --- Auth / JWT (required for token signing) ---
JWT_SECRET=
JWT_EXPIRES_IN=7d
COOKIE_DOMAIN=localhost

# --- CORS (comma-separated origins; empty = allow all in dev) ---
# CORS_ORIGINS=http://localhost:3100,http://localhost:3101,http://localhost:3102,http://localhost:3103,http://localhost:3104,http://localhost:3105,http://localhost:3106

# --- Public URLs (share links, callbacks, redirects) ---
API_PUBLIC_BASE_URL=
BACKEND_PUBLIC_URL=
APP_URL=
PUBLIC_WEB_URL=
PUBLIC_DEEPLINK_SCHEME=bpa
PANEL_PUBLIC_URL=
OWNER_WEB_URL=
OWNER_APP_URL=
PUBLIC_OWNER_APP_URL=
ADMIN_APP_URL=
PUBLIC_ADMIN_APP_URL=
COUNTRY_PANEL_PUBLIC_URL=
CAMPAIGN_LANDING_URL=
CAMPAIGN_BASE_URL=
FRONTEND_BASE_URL=
FRONTEND_URL=
WEB_APP_URL=
PRODUCER_PANEL_URL=
APP_BASE_URL=
PUBLIC_API_BASE_URL=
PUBLIC_BASE_URL=

# --- Super Admin (seed / login whitelist) ---
SUPER_ADMIN_PHONE=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_NAME=
SUPER_ADMIN_WHITELIST_EMAILS=
SUPER_ADMIN_WHITELIST_PHONES=
ADMIN_EMAILS=
ADMIN_PHONES=
ADMIN_USER_IDS=
ADMIN_KEY=
ADMIN_2FA_REQUIRED=false
ADMIN_2FA_TOTP_SECRET=

# --- OAuth providers (optional — social login) ---
# Google: verify id_token from web/mobile clients
GOOGLE_CLIENT_ID=
# Facebook: verify access_token via Graph API debug_token
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Object storage: minio (dev) | b2 (production) ---
STORAGE_PROVIDER=minio
STORAGE_USE_COUNTRY_PREFIX=true
STORAGE_PUBLIC_URL=
MINIO_PUBLIC_URL=
STORAGE_USE_PRESIGNED_PRIVATE_URLS=false
# STORAGE_SKIP_STARTUP_CHECK=true

# MinIO / S3-compatible (dev defaults when STORAGE_PROVIDER=minio)
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
AWS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_FORCE_PATH_STYLE=true

# Backblaze B2 (production — STORAGE_PROVIDER=b2)
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_FORCE_PATH_STYLE=true

# --- Redis (BullMQ notifications, OTP, queues) ---
REDIS_ENABLED=false
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_USERNAME=
# REDIS_DB=0
# REDIS_TLS=false
# REDIS_CONNECT_TIMEOUT_MS=5000
# REDIS_MAX_CONNECT_RETRIES=10

# --- SMS (BulkSMSBD primary, SSL Wireless fallback) ---
# --- SMS (BulkSMSBD primary) ---
SMS_ENABLED=true
SMS_PROVIDER=bulksmsbd
SMS_PRIMARY_PROVIDER=bulksmsbd
SMS_FALLBACK_PROVIDER=ssl_wireless
SMS_API_METHOD=GET
SMS_API_URL=http://bulksmsbd.net/api/smsapi
SMS_BALANCE_API_URL=http://bulksmsbd.net/api/getBalanceApi
SMS_API_KEY=
SMS_SENDER_ID=
SMS_SENDER_TYPE=NonMask
SMS_DEFAULT_TYPE=text
SMS_BASE_URL=http://bulksmsbd.net/api
SMS_TIMEOUT_MS=15000
SMS_HTTP_TIMEOUT_MS=15000
SMS_DEFAULT_COUNTRY_CODE=880
SMS_IP_WHITELIST_ENABLED=false
SMS_QUEUE_ATTEMPTS=3
SMS_QUEUE_BACKOFF_MS=5000
SMS_WORKER_CONCURRENCY=5
SMS_STUCK_RECOVERY_MINUTES=15
SMS_CHARS_PER_SEGMENT=160
SMS_COST_PER_SEGMENT_BDT=0.25
SMS_HTTP_TIMEOUT_MS=15000
# SMS_ALLOW_MOCK=true
# SMS_ALLOW_DEV_FAKE_SENT=true

# SSL Wireless
SSL_WIRELESS_API_TOKEN=
SSL_WIRELESS_SENDER_ID=
SSL_WIRELESS_BASE_URL=https://smsplus.sslwireless.com

# BulkSMSBD
BULKSMSBD_API_TOKEN=
BULKSMSBD_API_KEY=
BULKSMSBD_SENDER_ID=
BULKSMSBD_BASE_URL=http://bulksmsbd.net/api
BULKSMSBD_API_MODE=legacy
BULKSMSBD_LEGACY_URL=http://bulksmsbd.net/api/smsapi
CAMPAIGN_SMS_SENDER_ID=
CAMPAIGN_SMS_WEBHOOK_SECRET=

# --- Email (SMTP — optional; required for email worker) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=

# --- Payment gateway (sslcommerz | amarpay | bkash | nagad | eps) ---
PAYMENT_PROVIDER=eps
PAYMENT_WEBHOOK_SECRET=
PAYMENT_RECOVERY_INTERVAL_MS=600000
CAMPAIGN_PAYMENT_WEBHOOK_SECRET=
CAMPAIGN_PAYMENT_TIMEOUT_MINUTES=30
# Branch id for campaign checkout orders (orders.branchId).
# Resolution order: CAMPAIGN_PAYMENT_BRANCH_ID → organizer ACTIVE branch → any ACTIVE branch.
# Production: run `npm run bootstrap:campaign-branch` once, then set the printed id here.
# CAMPAIGN_PAYMENT_BRANCH_ID=1
# Public HTTPS base for EPS/browser callbacks (required in production)
# API_PUBLIC_BASE_URL=https://api.example.com
# CAMPAIGN_LANDING_URL=https://vaccination.example.com
# CAMPAIGN_PAYMENT_CALLBACK_PREFIX=

# SSLCommerz
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=true
# SSLCOMMERZ_SUCCESS_URL=
# SSLCOMMERZ_FAIL_URL=
# SSLCOMMERZ_CANCEL_URL=
# SSLCOMMERZ_IPN_URL=
# SSLCOMMERZ_SESSION_URL=
# SSLCOMMERZ_VALIDATION_URL=

# EPS (Easy Payment System)
EPS_BASE_URL=https://sandboxpgapi.eps.com.bd
EPS_USERNAME=
EPS_PASSWORD=
EPS_HASH_KEY=
# EPS_HASH=
EPS_MERCHANT_ID=
EPS_STORE_ID=
EPS_SANDBOX=true
# EPS_CALLBACK_URL=
# EPS_SUCCESS_URL=
# EPS_FAIL_URL=
# EPS_CANCEL_URL=
# EPS_TIMEOUT_MS=30000

# bKash
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_SANDBOX=true
# BKASH_BASE_URL=
# BKASH_CALLBACK_URL=

# Nagad
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PRIVATE_KEY=
NAGAD_PUBLIC_KEY=
NAGAD_SANDBOX=true
# NAGAD_BASE_URL=
# NAGAD_CALLBACK_URL=

# AmarPay
AMARPAY_STORE_ID=
AMARPAY_SIGNATURE_KEY=
AMARPAY_SANDBOX=true
# AMARPAY_BASE_URL=
# AMARPAY_IPN_URL=

# --- Campaign / vaccination booking ---
CAMPAIGN_JWT_SECRET=
CAMPAIGN_QR_SECRET=
CAMPAIGN_TEST_OTP=
# CAMPAIGN_BOOKING_COUPONS=
CAMPAIGN_SIMPLIFIED_BOOKING=true

# --- Wallet / payouts ---
WALLET_PAYOUT_DETAILS_KEY=
WALLET_PAYOUT_MODE=semi
WALLET_PAYOUT_MAX_ATTEMPTS=5
WALLET_PAYOUT_RETRY_DELAY_SECONDS=300
WEBHOOK_SIGNATURE_REQUIRED=false

# --- Product authenticity (HMAC / encryption) ---
AUTH_SERIAL_SIGNING_SECRET=
AUTH_CODE_HMAC_SECRET=
AUTH_CODE_ENC_SECRET=

# --- Country / policy ---
COUNTRY_DEFAULT=BD
POLICY_CACHE_TTL_SEC=300
VERIFICATION_HARD_LOCK=true
KYC_EXPIRY_DAYS=45
KYC_RETENTION_GRACE_DAYS=7

# --- File upload / media ---
MAX_UPLOAD_BYTES=104857600
IMAGE_MAX_SIDE=1600
IMAGE_JPEG_QUALITY=82
VIDEO_TRANSCODE=false
VIDEO_TRANSCODE_MAX_MB=80
PROFILE_PHOTO_MAX_SIDE=512
PROFILE_PHOTO_WEBP_QUALITY=82
FFMPEG_PATH=
UPLOAD_DIR=uploads

# --- Rate limits (optional overrides) ---
# RL_GENERAL_WINDOW_MS=900000
# RL_GENERAL_MAX=300
# RL_AUTH_WINDOW_MS=900000
# RL_AUTH_MAX=20
# RL_DONATION_WINDOW_MS=60000
# RL_DONATION_MAX=30
# RL_GEOCODE_WINDOW_MS=60000
# RL_GEOCODE_MAX=60
# RL_INVENTORY_WAREHOUSE_MUTATION_WINDOW_MS=60000
# RL_INVENTORY_WAREHOUSE_MUTATION_MAX=120

# --- Donations / fundraising ---
DONATION_FRAUD_MAX_PER_HOUR=5
DONATION_POINTS_PER_100=1
GOVT_REPORTING_DONATION_THRESHOLD=50000
GOVT_REPORTING_WEBHOOK_URL=

# --- Background jobs (intervals) ---
EXPIRY_ENGINE_INTERVAL_MS=86400000
NOTIFICATION_RETENTION_INTERVAL_MS=86400000
NOTIFICATIONS_RETENTION_DAYS_READ=90
NOTIFICATION_RETENTION_PRODUCER_ONLY=true
INVITE_CLEANUP_INTERVAL_MS=900000
OWNERS_AUTOMATION_ENABLED=1
OWNERS_CHECK_INTERVAL_MS=3600000
OWNERS_SYNC_INTERVAL_MS=21600000
OWNERS_AUDIT_EXPORT_DIR=./backups/logs
OWNERS_ANOMALY_THRESHOLD=100
SLACK_WEBHOOK_URL=

# --- AI / inventory feature flags ---
AI_AUTO_DRAFT_STOCK_REQUEST=false
AUTO_PROCUREMENT_DEMAND_DISPATCH=
MULTI_SOURCE_ALLOCATION_ENABLED=
FULFILLMENT_RESERVATION_ENABLED=
WRITEOFF_AUTO_APPROVE_MAX_QTY=10
WRITEOFF_AUTO_APPROVE_MAX_COST=1000

# --- Legacy inventory guards (optional) ---
# DISABLE_LEGACY_STOCK_REQUEST_FULFILL=
# DISABLE_LEGACY_STOCK_TRANSFER=
# BLOCK_LEGACY_TRANSFERS=
# ALLOW_LEGACY_FULFILL_WITH_ALLOCATION_DRAFT=
# ENTERPRISE_DISPATCH_RECEIVE_SESSION_ONLY=

# --- Validation flags (for npm run validate:env) ---
# VALIDATE_PAYMENT_CONFIG=true
# VALIDATE_SMTP=true
