  message      String
  provider     String       @db.VarChar(32)
  status       SmsLogStatus @default(QUEUED)
  response     String?
  template     String?      @db.VarChar(64)
  externalId   String?      @db.VarChar(64)
  errorMessage String?
  attemptCount Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  sentAt       DateTime?

  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("sms_logs")
}

model CampaignAuditLog {
  id         Int @id @default(autoincrement())
  campaignId Int

  // Actor
  actorUserId Int?
  actorRole   String?
  actorIp     String? @db.VarChar(45)

  // Action
  action     String @db.VarChar(64)
  entityType String @db.VarChar(32)
  entityId   Int?

  // Details
  beforeJson   Json?
  afterJson    Json?
  metadataJson Json?

  // Timestamp
  createdAt DateTime @default(now())

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actor    User?    @relation("CampaignAuditLogActor", fields: [actorUserId], references: [id])

  @@index([campaignId, createdAt])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@map("campaign_audit_logs")
}

model CampaignRolloutPhase {
  id                 Int                        @id @default(autoincrement())
  campaignId         Int
  phaseCode          CampaignRolloutPhaseCode
  name               String
  description        String?
  status             CampaignRolloutPhaseStatus @default(PLANNED)
  sortOrder          Int                        @default(0)
  nationwideGoalPets Int                        @default(10000)
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  campaign Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  regions  CampaignRolloutRegion[]

  @@unique([campaignId, phaseCode])
  @@index([campaignId, status])
  @@map("campaign_rollout_phases")
}

model CampaignRolloutRegion {
  id             Int      @id @default(autoincrement())
  phaseId        Int
  campaignId     Int
  divisionId     Int?
  districtId     Int?
  upazilaId      Int?
  city           String?
  venueName      String?
  venueAddress   String?
  locationId     Int?
  startDate      DateTime?
  endDate        DateTime?
  targetCapacity Int      @default(0)
  bookedCount    Int      @default(0)
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  phase            CampaignRolloutPhase      @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  campaign         Campaign                  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location         CampaignLocation?         @relation(fields: [locationId], references: [id], onDelete: SetNull)
  preRegistrations CampaignPreRegistration[]
  checkoutSessions CampaignCheckoutSession[]
  bookings         CampaignBooking[]

  @@index([campaignId, isActive])
  @@index([phaseId])
  @@index([divisionId, districtId, upazilaId])
  @@map("campaign_rollout_regions")
}

model CampaignPreRegistration {
  id         Int                           @id @default(autoincrement())
  campaignId Int
  regionId   Int?
  divisionId Int?
  districtId Int?
  upazilaId  Int?
  phone      String                        @db.VarChar(20)
  catCount   Int                           @default(1)
  status     CampaignPreRegistrationStatus @default(WAITING)
  notifiedAt DateTime?
  createdAt  DateTime                      @default(now())
  updatedAt  DateTime                      @updatedAt

  campaign Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  region   CampaignRolloutRegion?   @relation(fields: [regionId], references: [id], onDelete: SetNull)

  @@index([campaignId, status])
  @@index([phone])
  @@index([districtId])
  @@map("campaign_pre_registrations")
}

model CampaignCheckoutSession {
  id              String                 @id @default(cuid())
  campaignId      Int
  rolloutRegionId Int?
  ownerPhone      String                 @db.VarChar(15)
  alternatePhone  String?                @db.VarChar(15)
  addressJson     Json
  catCount        Int
  couponCode      String?                @db.VarChar(32)
  paymentMethod   String?                @db.VarChar(20)
  amount          Decimal                @db.Decimal(10, 2)
  status          CampaignCheckoutStatus @default(PENDING)
  orderId         Int?
  bookingId       Int?
  expiresAt       DateTime
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  campaign      Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  rolloutRegion CampaignRolloutRegion? @relation(fields: [rolloutRegionId], references: [id], onDelete: SetNull)
  order         Order?                 @relation("CampaignCheckoutOrder", fields: [orderId], references: [id], onDelete: SetNull)
  booking       CampaignBooking?

  @@index([ownerPhone])
  @@index([status, expiresAt])
  @@index([campaignId])
  @@map("campaign_checkout_sessions")
}

