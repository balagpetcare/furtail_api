generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model AnimalCategory {
  id           Int          @id @default(autoincrement())
  code         String       @unique
  name         String
  displayOrder Int          @default(0)
  isActive     Boolean      @default(true)
  animalTypes  AnimalType[]

  @@map("animal_categories")
}

model AnimalType {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  categoryId     Int?
  code           String?         @unique
  scientificName String?         @db.VarChar(128)
  icon           String?         @db.VarChar(64)
  displayOrder   Int?            @default(0)
  isActive       Boolean?        @default(true)
  category       AnimalCategory? @relation(fields: [categoryId], references: [id])
  breeds         Breed[]
  pets           Pet[]
  vaccineTypes   VaccineType[]
  // Campaign 2026 relations
  campaignPets   CampaignPet[]   @relation("CampaignPetAnimalType")

  @@map("animal_types")
}

model AnimalSize {
  id            Int     @id @default(autoincrement())
  code          String  @unique
  name          String
  minWeightKg   Float?
  maxWeightKg   Float?
  displayOrder  Int     @default(0)
  isActive      Boolean @default(true)
  breedsDefault Breed[]
  pets          Pet[]

  @@map("animal_sizes")
}

model AnimalColor {
  id           Int     @id @default(autoincrement())
  code         String  @unique
  name         String
  hexPreview   String? @db.VarChar(16)
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  pets         Pet[]

  @@map("animal_colors")
}

model CoatPattern {
  id           Int     @id @default(autoincrement())
  code         String  @unique
  name         String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  pets         Pet[]

  @@map("coat_patterns")
}

model Breed {
  id            Int           @id @default(autoincrement())
  name          String
  animalTypeId  Int
  code          String?       @db.VarChar(64)
  aliasNames    Json?
  originCountry String?       @db.VarChar(64)
  defaultSizeId Int?
  isMixed       Boolean       @default(false)
  isOther       Boolean       @default(false)
  displayOrder  Int?          @default(0)
  isActive      Boolean?      @default(true)
  animalType    AnimalType    @relation(fields: [animalTypeId], references: [id])
  defaultSize   AnimalSize?   @relation(fields: [defaultSizeId], references: [id])
  pets          Pet[]
  subBreeds     SubBreed[]
  // Campaign 2026 relations
  campaignPets  CampaignPet[] @relation("CampaignPetBreed")

  @@unique([name, animalTypeId])
  @@map("breeds")
}

model SubBreed {
  id           Int     @id @default(autoincrement())
  breedId      Int
  code         String  @db.VarChar(64)
  name         String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  pets         Pet[]
  breed        Breed   @relation(fields: [breedId], references: [id])

  @@unique([breedId, code])
  @@map("sub_breeds")
}

model UserAuth {
  id                Int          @id @default(autoincrement())
  userId            Int          @unique
  provider          AuthProvider @default(LOCAL)
  email             String?      @unique
  phone             String?      @unique
  passwordHash      String?
  passwordUpdatedAt DateTime?
  emailVerifiedAt   DateTime?
  phoneVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  failedAttempts    Int          @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  /// OIDC subject (e.g. Google "sub") Ã¢â‚¬â€ set for OAuth-linked accounts
  oauthSubject      String?
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, oauthSubject])
  @@index([email])
  @@index([phone])
  @@index([oauthSubject])
  @@map("user_auth")
}

model UserProfile {
  id                   Int               @id @default(autoincrement())
  userId               Int               @unique
  displayName          String
  username             String            @unique
  bio                  String?
  visibility           ProfileVisibility @default(PUBLIC)
  showEmail            Boolean           @default(false)
  showPhone            Boolean           @default(false)
  avatarMediaId        Int?
  coverMediaId         Int?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  /// Self-service optional personal fields (enterprise profile hub)
  gender               Gender?
  dateOfBirth          DateTime?
  divisionId           Int?
  districtId           Int?
  upazilaId            Int?
  unionId              Int?
  areaId               Int?
  addressJson          Json?
  emergencyContactJson Json?
  /// Last OAuth provider snapshot (does not replace manual displayName unless placeholder)
  providerDisplayName  String?           @db.VarChar(256)
  providerAvatarUrl    String?
  providerKey          String?           @db.VarChar(32)
  providerSyncedAt     DateTime?
  avatarMedia          Media?            @relation("UserAvatar", fields: [avatarMediaId], references: [id])
  coverMedia           Media?            @relation("UserCover", fields: [coverMediaId], references: [id])
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([divisionId])
  @@index([districtId])
  @@index([upazilaId])
  @@index([unionId])
  @@index([areaId])
  @@map("user_profiles")
}

model UserStatsCache {
  userId         Int      @id
  followersCount Int      @default(0)
  followingCount Int      @default(0)
  petsCount      Int      @default(0)
  pawPoints      Int      @default(0)
  rankGlobal     Int?
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats_cache")
}

model UserSession {
  id               Int       @id @default(autoincrement())
  userId           Int
  refreshTokenHash String    @unique
  deviceId         String?
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model UserFollow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
  @@map("user_follows")
}

model UserProfileLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  likedById Int
  createdAt DateTime @default(now())
  likedBy   User     @relation("UserProfileLiker", fields: [likedById], references: [id], onDelete: Cascade)
  user      User     @relation("UserProfileLiked", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, likedById])
  @@index([userId])
  @@index([likedById])
  @@map("user_profile_likes")
}

model UserFriendRequest {
  id         Int                 @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  fromUser   User                @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User                @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId])
  @@map("user_friend_requests")
}

model UserFriend {
  id        Int      @id @default(autoincrement())
  userAId   Int
  userBId   Int
  createdAt DateTime @default(now())
  userA     User     @relation("UserFriendA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("UserFriendB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@map("user_friends")
}

model Achievement {
  id             Int               @id @default(autoincrement())
  code           String            @unique
  title          String
  description    String?
  requiredPoints Int               @default(0)
  pointsReward   Int               @default(0)
  howTo          String?
  iconMediaId    Int?
  createdAt      DateTime          @default(now())
  iconMedia      Media?            @relation("AchievementIcon", fields: [iconMediaId], references: [id])
  users          UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            Int         @id @default(autoincrement())
  userId        Int
  achievementId Int
  unlockedAt    DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model UserGalleryItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  mediaId   Int
  caption   String?
  createdAt DateTime @default(now())
  deleted   Boolean  @default(false)
  media     Media    @relation("UserGalleryMedia", fields: [mediaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_gallery_items")
}

model User {
  id                                      Int                                  @id @default(autoincrement())
  status                                  UserStatus                           @default(ACTIVE)
  createdAt                               DateTime                             @default(now())
  updatedAt                               DateTime                             @updatedAt
  currentPlaceId                          Int?
  tokenVersion                            Int                                  @default(0)
  appointmentsAsPatient                   Appointment[]                        @relation("AppointmentPatient")
  branchMembersInvited                    BranchMember[]                       @relation("BranchMemberInvitedBy")
  branchMemberships                       BranchMember[]
  branchProfilesReviewed                  BranchProfileDetails[]               @relation("BranchKycReviewedBy")
  donations                               Donation[]
  fundraisingAccountStatusLogsAsAdmin     FundraisingAccountStatusLog[]        @relation("FundraisingAccountStatusLogAdminUser")
  fundraisingAccount                      FundraisingAccount?
  fundraisingWithdrawRequestsAsAdmin      FundraisingWithdrawRequest[]         @relation("FundraisingWithdrawAdminUser")
  uploadedMedia                           Media[]                              @relation("UserUploadedMedia")
  notificationReads                       NotificationRead[]
  notificationsSent                       Notification[]                       @relation("NotificationSender")
  notifications                           Notification[]
  ordersCreated                           Order[]                              @relation("OrderCreatedBy")
  ordersAsCustomer                        Order[]                              @relation("OrderCustomer")
  orgLegalProfilesReviewed                OrganizationLegalProfile[]           @relation("OrgKycReviewedBy")
  ownedOrganizations                      Organization[]
  ownerKycReviewed                        OwnerKyc[]                           @relation("OwnerKycReviewedBy")
  ownerKyc                                OwnerKyc?
  ownerOnboardingState                    OwnerOnboardingState?
  ownerProfile                            OwnerProfile?
  pets                                    Pet[]
  postCommentLikes                        PostCommentLike[]
  postComments                            PostComment[]
  postLikes                               PostLike[]
  posts                                   Post[]
  reports                                 Report[]                             @relation("UserReports")
  rewardHistories                         RewardHistory[]
  servicesCreated                         Service[]                            @relation("ServiceCreatedBy")
  achievements                            UserAchievement[]
  appSettings                             UserAppSettings?
  auth                                    UserAuth?
  followsFollowing                        UserFollow[]                         @relation("UserFollowing")
  followsFollowers                        UserFollow[]                         @relation("UserFollowers")
  friendRequestsSent                      UserFriendRequest[]                  @relation("FriendRequestFrom")
  friendRequestsReceived                  UserFriendRequest[]                  @relation("FriendRequestTo")
  friendsA                                UserFriend[]                         @relation("UserFriendA")
  friendsB                                UserFriend[]                         @relation("UserFriendB")
  galleryItems                            UserGalleryItem[]
  locationEvents                          UserLocationEvent[]
  locationProfile                         UserLocationProfile?
  notificationPrefs                       UserNotificationPrefs?
  profileLikesGiven                       UserProfileLike[]                    @relation("UserProfileLiker")
  profileLikesReceived                    UserProfileLike[]                    @relation("UserProfileLiked")
  profile                                 UserProfile?
  sessions                                UserSession[]
  stats                                   UserStatsCache?
  wallet                                  UserWallet?
  currentPlace                            Place?                               @relation(fields: [currentPlaceId], references: [id])
  verificationCaseEventsAdmin             VerificationCaseEvent[]              @relation("VerificationCaseEventAdmin")
  verificationCasesReviewed               VerificationCase[]                   @relation("VerificationCaseReviewedBy")
  verificationDocsChecked                 VerificationDocument[]               @relation("VerificationDocCheckedBy")
  verificationLockedAttempts              VerificationLockedUpdateAttempt[]
  verificationLogsAsAdmin                 VerificationLog[]                    @relation("VerificationLogAdmin")
  visitsAsPatient                         Visit[]                              @relation("VisitPatient")
  walletWithdrawRequestsAsAdmin           WalletWithdrawRequest[]              @relation("WalletWithdrawAdminUser")
  walletWithdrawRequests                  WalletWithdrawRequest[]
  managedWarehouses                       Warehouse[]                          @relation("WarehouseManager")
  // Campaign 2026 relations
  campaignBookingsAsOwner                 CampaignBooking[]                    @relation("CampaignBookingOwner")
  campaignBookingsCheckedIn               CampaignBooking[]                    @relation("CampaignBookingCheckedInBy")
  campaignStaffAssignments                CampaignStaff[]                      @relation("CampaignStaffUser")
  campaignAuditLogs                       CampaignAuditLog[]                   @relation("CampaignAuditLogActor")

  @@map("users")
}

model Place {
  id                    Int      @id @default(autoincrement())
  latitude              Float
  longitude             Float
  countryCode           String?
  stateName             String?
  cityName              String?
  formattedAddress      String?  @db.VarChar(1024)
  rawAddressJson        Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  usersWithCurrentPlace User[]

  @@index([latitude, longitude])
  @@map("places")
}

model LocationPlace {
  id                            Int                   @id @default(autoincrement())
  countryCode                   String
  admin1                        String?
  admin2                        String?
  city                          String?
  postalCode                    String?
  formattedAddress              String?               @db.VarChar(1024)
  lat                           Float?
  lng                           Float?
  geoHash                       String?
  source                        LocationSource?
  sourcePlaceId                 String?
  bdDivision                    String?
  bdDistrict                    String?
  bdUpazila                     String?
  bdWard                        String?
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt
  userLocationEvents            UserLocationEvent[]
  userLocationProfilesAsCurrent UserLocationProfile[] @relation("CurrentPlace")
  userLocationProfilesAsHome    UserLocationProfile[] @relation("HomePlace")
  userLocationProfilesAsManual  UserLocationProfile[] @relation("ManualOverridePlace")

  @@index([countryCode, admin1, city])
  @@index([geoHash])
  @@map("location_places")
}

model UserLocationProfile {
  userId                Int                    @unique
  homePlaceId           Int?
  currentPlaceId        Int?
  manualOverridePlaceId Int?
  lastLat               Float?
  lastLng               Float?
  precisionLevel        LocationPrecisionLevel
  consentLevel          LocationConsentLevel
  lastUpdatedAt         DateTime               @default(now())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  currentPlace          LocationPlace?         @relation("CurrentPlace", fields: [currentPlaceId], references: [id])
  homePlace             LocationPlace?         @relation("HomePlace", fields: [homePlaceId], references: [id])
  manualOverridePlace   LocationPlace?         @relation("ManualOverridePlace", fields: [manualOverridePlaceId], references: [id])
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_location_profiles")
}

model UserLocationEvent {
  id             Int               @id @default(autoincrement())
  userId         Int
  timestamp      DateTime
  lat            Float
  lng            Float
  placeId        Int?
  accuracyMeters Float?
  source         LocationSource
  eventType      LocationEventType
  sessionId      String?
  deviceId       String?
  createdAt      DateTime          @default(now())
  place          LocationPlace?    @relation(fields: [placeId], references: [id])
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp(sort: Desc)])
  @@map("user_location_events")
}

model OwnerProfile {
  id           Int       @id @default(autoincrement())
  userId       Int       @unique
  name         String
  supportPhone String?
  supportEmail String?
  divisionId   Int?
  districtId   Int?
  upazilaId    Int?
  unionId      Int?
  areaId       Int?
  nid          String?
  dateOfBirth  DateTime?
  genderText   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  addressJson  Json?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([divisionId])
  @@index([districtId])
  @@index([upazilaId])
  @@index([unionId])
  @@index([areaId])
  @@map("owner_profiles")
}

model OwnerKyc {
  id                    Int                @id @default(autoincrement())
  userId                Int                @unique
  fullName              String
  fatherName            String?
  motherName            String?
  dateOfBirth           DateTime?
  genderText            String?
  nationality           String?            @default("Bangladeshi")
  nidNumber             String?
  nidIssueDate          DateTime?
  nidAddressRaw         String?
  mobile                String?
  email                 String?
  presentAddressJson    Json?
  permanentAddressJson  Json?
  emergencyContactName  String?
  emergencyContactPhone String?
  verificationStatus    VerificationStatus @default(UNSUBMITTED)
  submittedAt           DateTime?
  reviewedAt            DateTime?
  reviewedByAdminId     Int?
  reviewNote            String?
  rejectionReason       String?
  riskScore             Int?               @default(0)
  isLocked              Boolean            @default(false)
  lockReason            String?
  deletedAt             DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  businessIntentJson    Json?
  declarationsJson      Json?
  expiresAt             DateTime?
  kycLevel              Int?               @default(0)
  reviewedByAdmin       User?              @relation("OwnerKycReviewedBy", fields: [reviewedByAdminId], references: [id])
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents             OwnerKycDocument[]

  @@index([verificationStatus])
  @@index([reviewedByAdminId])
  @@index([expiresAt])
  @@map("owner_kyc")
}

model OwnerKycDocument {
  id         Int            @id @default(autoincrement())
  ownerKycId Int
  type       DocumentType
  status     DocumentStatus @default(SUBMITTED)
  mediaId    Int
  docNumber  String?
  issueDate  DateTime?
  expiryDate DateTime?
  note       String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  media      Media          @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  ownerKyc   OwnerKyc       @relation(fields: [ownerKycId], references: [id], onDelete: Cascade)

  @@index([ownerKycId])
  @@index([type])
  @@map("owner_kyc_documents")
}

model OrganizationLegalProfile {
  id                     Int                    @id @default(autoincrement())
  orgId                  Int                    @unique
  organizationName       String
  registrationType       RegistrationType       @default(PROPRIETORSHIP)
  tradeLicenseNumber     String?
  tradeLicenseIssueDate  DateTime?
  tradeLicenseExpiryDate DateTime?
  issuingAuthority       String?
  tinNumber              String?
  binNumber              String?
  officialPhone          String?
  officialEmail          String?
  website                String?
  facebookPage           String?
  bankAccountName        String?
  bankAccountNumber      String?
  bankName               String?
  bankBranchName         String?
  routingNumber          String?
  payoutBkash            String?
  payoutNagad            String?
  payoutRocket           String?
  verificationStatus     VerificationStatus     @default(UNSUBMITTED)
  submittedAt            DateTime?
  reviewedAt             DateTime?
  reviewedByAdminId      Int?
  reviewNote             String?
  rejectionReason        String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  organization           Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  reviewedByAdmin        User?                  @relation("OrgKycReviewedBy", fields: [reviewedByAdminId], references: [id])

  @@index([verificationStatus])
  @@index([reviewedByAdminId])
  @@map("org_legal_profiles")
}

model BranchProfileDetails {
  id                 Int                @id @default(autoincrement())
  branchId           Int                @unique
  branchPhone        String?
  branchEmail        String?
  managerName        String?
  managerPhone       String?
  managerNidNumber   String?
  addressJson        Json?
  latitude           Float?
  longitude          Float?
  googleMapLink      String?
  openingHoursJson   Json?
  weeklyOffDaysJson  Json?
  vetLicenseNumber   String?
  drugLicenseNumber  String?
  verificationStatus VerificationStatus @default(UNSUBMITTED)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedByAdminId  Int?
  reviewNote         String?
  rejectionReason    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  coveragePolygon    Json?
  coverageRadiusKm   Float?
  branch             Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  reviewedByAdmin    User?              @relation("BranchKycReviewedBy", fields: [reviewedByAdminId], references: [id])

  @@index([verificationStatus])
  @@index([reviewedByAdminId])
  @@map("branch_profile_details")
}

model VerificationLog {
  id          Int                    @id @default(autoincrement())
  entityType  VerificationEntityType
  entityId    Int
  action      VerificationAction
  fromStatus  VerificationStatus?
  toStatus    VerificationStatus?
  adminUserId Int?
  note        String?
  createdAt   DateTime               @default(now())
  adminUser   User?                  @relation("VerificationLogAdmin", fields: [adminUserId], references: [id])

  @@index([entityType, entityId])
  @@index([adminUserId])
  @@map("verification_logs")
}

model VerificationCase {
  id                Int                     @id @default(autoincrement())
  entityType        VerificationEntityType
  entityId          Int
  status            VerificationCaseStatus  @default(DRAFT)
  submittedAt       DateTime?
  reviewedAt        DateTime?
  reviewedByAdminId Int?
  reviewSummary     String?
  lockReason        String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  isLocked          Boolean                 @default(false)
  /// V2: Owner/Org/Branch draft data snapshot (non-breaking add-only)
  /// This keeps Flutter/public APIs untouched while Owner Panel uses a unified verification case payload.
  payloadJson       Json?
  events            VerificationCaseEvent[]
  reviewedByAdmin   User?                   @relation("VerificationCaseReviewedBy", fields: [reviewedByAdminId], references: [id])
  documents         VerificationDocument[]

  @@index([entityType, entityId])
  @@index([status])
  @@index([reviewedByAdminId])
  @@map("verification_cases")
}

model VerificationDocument {
  id               Int                   @id @default(autoincrement())
  caseId           Int
  docType          DocumentType
  status           VerificationDocStatus @default(PENDING)
  isRequired       Boolean               @default(true)
  mediaId          Int
  version          Int                   @default(1)
  docNumber        String?
  issueDate        DateTime?
  expiryDate       DateTime?
  rejectReason     String?
  instruction      String?
  checkedAt        DateTime?
  checkedByAdminId Int?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  verificationCase VerificationCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  checkedByAdmin   User?                 @relation("VerificationDocCheckedBy", fields: [checkedByAdminId], references: [id])
  media            Media                 @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([docType])
  @@index([status])
  @@index([checkedByAdminId])
  @@map("verification_documents")
}

model VerificationCaseEvent {
  id               Int                     @id @default(autoincrement())
  caseId           Int
  action           VerificationAction
  from             VerificationCaseStatus?
  to               VerificationCaseStatus?
  actorAdminId     Int?
  note             String?
  createdAt        DateTime                @default(now())
  actorAdmin       User?                   @relation("VerificationCaseEventAdmin", fields: [actorAdminId], references: [id])
  verificationCase VerificationCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([actorAdminId])
  @@map("verification_case_events")
}

model Notification {
  id                   Int                             @id @default(autoincrement())
  userId               Int
  type                 NotificationType
  title                String
  message              String
  meta                 Json?
  readAt               DateTime?
  createdAt            DateTime                        @default(now())
  priority             NotificationPriority            @default(P2)
  status               NotificationStatus              @default(ACTIVE)
  actionUrl            String?                         @db.VarChar(1024)
  dedupeKey            String?                         @db.VarChar(255)
  expiresAt            DateTime?
  recipientScopeType   NotificationRecipientScopeType?
  recipientScopeId     String?                         @db.VarChar(255)
  orgId                Int?
  branchId             Int?
  severity             String?                         @db.VarChar(32)
  source               String?                         @db.VarChar(64)
  senderId             Int?
  deliveries           NotificationDelivery[]
  reads                NotificationRead[]
  vaccinationReminders VaccinationReminder[]
  sender               User?                           @relation("NotificationSender", fields: [senderId], references: [id])
  user                 User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
  @@index([dedupeKey])
  @@index([orgId])
