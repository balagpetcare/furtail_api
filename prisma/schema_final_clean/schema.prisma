  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  transferLog FundraisingPayoutTransferLog?

  @@index([campaignId, createdAt])
  @@index([accountId, createdAt])
  @@index([status, createdAt])
  @@index([adminUserId])
  @@map("fundraising_withdraw_requests")
}

model FundraisingPayoutTransferLog {
