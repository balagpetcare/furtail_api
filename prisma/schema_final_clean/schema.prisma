  @@map("fundraising_payout_methods")
}

model FundraisingWithdrawRequest {
  id         Int                 @id @default(autoincrement())
  campaignId Int
  campaign   FundraisingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  accountId Int
  account   FundraisingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  methodId Int
  method   FundraisingPayoutMethod @relation(fields: [methodId], references: [id], onDelete: Restrict)

  amount Int
  status FundraisingWithdrawRequestStatus @default(SUBMITTED)

