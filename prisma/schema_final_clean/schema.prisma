  postId Int  @unique
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([campaignId, createdAt])
  @@map("fundraising_updates")
}

enum FundraisingAccountStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum FundraisingAccountType {
  INDIVIDUAL
  ORGANIZATION
}

enum FundraisingCampaignStatus {
  ACTIVE
  PAUSED
