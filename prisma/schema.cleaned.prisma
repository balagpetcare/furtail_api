model Warehouse {
  id                             Int                        @id @default(autoincrement())
  orgId                          Int
  name                           String                     @db.VarChar(200)
  code                           String?                    @db.VarChar(50)
  type                           WarehouseType              @default(CENTRAL)
  addressJson                    Json?
  location                       Json                       @default("{}")
  managerId                      Int?
  isActive                       Boolean                    @default(true)
  createdAt                      DateTime                   @default(now())
  updatedAt                      DateTime                   @updatedAt
  /// When true, vendor GRN receive creates pending QC rows; stock is not allocatable until inspection completes.
  qcInboundEnabled               Boolean                    @default(false)
  /// When set (>0) and failedQty meets threshold, inspection is flagged for escalation review.
  qcEscalationFailedQtyThreshold Int?
  /// Optional: when receiving against a PO whose grandTotal >= this, write an escalation audit row.
  poReceiveEscalationMinTotal    Decimal?                   @db.Decimal(14, 2)
  branchId                       Int?
  /// Max over-receipt vs ordered line qty: null = unlimited (legacy); 0 = no over; 5 = 5% over allowed.
  poOverReceiptTolerancePercent  Decimal?                   @db.Decimal(5, 2)
  locations                      InventoryLocation[]
  preferredByVendors             Vendor[]                   @relation("VendorPreferredWarehouse")
  zones                          WarehouseZone[]
  branch                         Branch?                    @relation(fields: [branchId], references: [id])
  manager                        User?                      @relation("WarehouseManager", fields: [managerId], references: [id])
  org                            Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, isActive])
  @@index([branchId])
  @@index([isActive])
  @@index([managerId])
  @@map("warehouses")
}

model WarehouseZone {
  id          Int                  @id @default(autoincrement())
  warehouseId Int
  code        String               @db.VarChar(64)
  name        String               @db.VarChar(200)
