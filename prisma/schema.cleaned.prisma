  upazilaId  Int?
  phone      String                        @db.VarChar(20)
  catCount   Int                           @default(1)
  status     CampaignPreRegistrationStatus @default(WAITING)
  notifiedAt DateTime?
  createdAt  DateTime                      @default(now())
  updatedAt  DateTime                      @updatedAt

  campaign Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  region   CampaignRolloutRegion?   @relation(fields: [regionId], references: [id], onDelete: SetNull)

  @@index([campaignId, status])
  @@index([phone])
  @@index([districtId])
  @@map("campaign_pre_registrations")
}

model CampaignCheckoutSession {
  id              String                 @id @default(cuid())
  campaignId      Int
  rolloutRegionId Int?
  ownerPhone      String                 @db.VarChar(15)
  alternatePhone  String?                @db.VarChar(15)
  addressJson     Json
  catCount        Int
  couponCode      String?                @db.VarChar(32)
  paymentMethod   String?                @db.VarChar(20)
  amount          Decimal                @db.Decimal(10, 2)
  status          CampaignCheckoutStatus @default(PENDING)
  orderId         Int?
  bookingId       Int?
  expiresAt       DateTime
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  campaign      Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  rolloutRegion CampaignRolloutRegion? @relation(fields: [rolloutRegionId], references: [id], onDelete: SetNull)
  order         Order?                 @relation("CampaignCheckoutOrder", fields: [orderId], references: [id], onDelete: SetNull)
  booking       CampaignBooking?

  @@index([ownerPhone])
  @@index([status, expiresAt])
  @@index([campaignId])
  @@map("campaign_checkout_sessions")
}

