  size                     AnimalSize?           @relation(fields: [sizeId], references: [id])
  subBreed                 SubBreed?             @relation(fields: [subBreedId], references: [id])
  user                     User                  @relation(fields: [userId], references: [id])
  surgeryCases             SurgeryCase[]
