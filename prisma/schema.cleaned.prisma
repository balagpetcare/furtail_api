  breedNameSnapshot        String?               @db.VarChar(128)
  subBreedNameSnapshot     String?               @db.VarChar(128)
  colorNameSnapshot        String?               @db.VarChar(64)
  coatPatternNameSnapshot  String?               @db.VarChar(64)
  sizeNameSnapshot         String?               @db.VarChar(32)
