  surgeryPackage            SurgeryPackage?            @relation(fields: [surgeryPackageId], references: [id])
  updatedBy                 User?                      @relation("SurgeryCaseUpdatedBy", fields: [updatedByUserId], references: [id])
  visit                     Visit?                     @relation(fields: [visitId], references: [id])

  @@index([branchId, status])
  @@index([branchId, scheduledStartAt])
  @@index([primaryDoctorId])
  @@index([patientId])
  @@index([petId])
  @@map("surgery_cases")
}

model ClinicInvoice {
