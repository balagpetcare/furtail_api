  allocatedDoses Int?
  usedDoses      Int  @default(0)

  // Status
  isActive Boolean @default(true)

  // Relations
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  vaccineType VaccineType @relation(fields: [vaccineTypeId], references: [id])

  @@unique([campaignId, vaccineTypeId])
  @@map("campaign_vaccine_types")
}

model CampaignIncludedVaccine {
  id              Int      @id @default(autoincrement())
  campaignId      Int
  name            String
  description     String?
  coveredDiseases Json     @default("[]")
  displayOrder    Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, displayOrder])
  @@map("campaign_included_vaccines")
}

model CampaignBooking {
  id Int @id @default(autoincrement())

  // Reference
  bookingRef String @unique @db.VarChar(12) // e.g., "VAC-ABC123"
  qrToken    String @unique @db.VarChar(32)

  // Campaign Link
  campaignId Int
  locationId Int?
  slotId     Int?
  bookingMode CampaignBookingMode @default(VENUE)

  // Owner (may or may not have BPA account)
  ownerUserId      Int? // NULL if not linked to BPA account
  ownerPhone       String @db.VarChar(15)
  ownerName        String
  ownerAddressJson Json?

  // Booking Details
  bookingDate DateTime @db.Date
  petCount    Int      @default(1)

  // Status
  status CampaignBookingStatus @default(CONFIRMED)

  // Check-in
  checkedInAt       DateTime?
  checkedInByUserId Int?
  queueNumber       String?   @db.VarChar(10)

  // Completion
  completedAt DateTime?

  // Walk-in flag
  isWalkIn Boolean @default(false)

  // Payment
  paymentStatus  CampaignPaymentStatus @default(NOT_REQUIRED)
  paymentOrderId Int? // Link to existing Order model
  paidAmount     Decimal?              @db.Decimal(10, 2)

  // Cancellation
  cancelledAt  DateTime?
  cancelReason String?
  refundStatus CampaignRefundStatus?
  refundAmount Decimal?              @db.Decimal(10, 2)

  // Linking
  linkSource String?   @db.VarChar(32)
  linkedAt   DateTime?

  // Simplified booking (2026 express flow)
  rolloutRegionId     Int?
  coverageZoneId      Int?
  coverageZoneName    String? @db.VarChar(200)
  bdAreaId            Int?
  bookingArea         String? @db.VarChar(200)
  checkoutSessionId   String? @unique @db.VarChar(32)
  ownerAlternatePhone String? @db.VarChar(15)

  // Metadata
  metadataJson Json?

  // Post-payment confirmation SMS (idempotent dispatch)
  smsSentAt    DateTime?
  smsReference String?   @db.VarChar(64)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  campaign        Campaign                 @relation(fields: [campaignId], references: [id])
  location        CampaignLocation?        @relation(fields: [locationId], references: [id])
  slot            CampaignSlot?            @relation(fields: [slotId], references: [id])
  rolloutRegion   CampaignRolloutRegion?   @relation(fields: [rolloutRegionId], references: [id], onDelete: SetNull)
  coverageZone    CoverageZone?            @relation(fields: [coverageZoneId], references: [id], onDelete: SetNull)
  bdArea          BdArea?                  @relation(fields: [bdAreaId], references: [id], onDelete: SetNull)
  checkoutSession CampaignCheckoutSession? @relation(fields: [checkoutSessionId], references: [id], onDelete: SetNull)
  owner           User?                    @relation("CampaignBookingOwner", fields: [ownerUserId], references: [id])
  checkedInBy     User?                    @relation("CampaignBookingCheckedInBy", fields: [checkedInByUserId], references: [id])
  paymentOrder    Order?                   @relation("CampaignBookingPaymentOrder", fields: [paymentOrderId], references: [id])
  pets                CampaignPet[]
  smsLogs             CampaignSmsLog[]
  vaccinations        Vaccination[]            @relation("CampaignVaccinations")
  paymentTransactions PaymentTransaction[]

  @@index([campaignId, bookingDate])
  @@index([rolloutRegionId])
  @@index([coverageZoneId])
  @@index([bdAreaId])
  @@index([bookingMode])
  @@index([ownerPhone])
  @@index([slotId, status])
  @@index([qrToken])
  @@index([bookingRef])
  @@index([status, bookingDate])
  @@map("campaign_bookings")
}

model CampaignPet {
  id        Int @id @default(autoincrement())
  bookingId Int

  // Pet Details
  name             String
  animalTypeId     Int     @default(2) // Default: Cat
  breedId          Int?
  gender           Gender?
  ageMonths        Int? // Approximate age in months
  colorDescription String?

