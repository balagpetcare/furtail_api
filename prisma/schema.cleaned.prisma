  sender               User?                           @relation("NotificationSender", fields: [senderId], references: [id])
  user                 User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
  @@index([dedupeKey])
  @@index([orgId])
  @@index([branchId])
  @@map("notifications")
}

