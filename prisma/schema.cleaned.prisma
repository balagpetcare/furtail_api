  sortOrder   Int                  @default(0)
  isActive    Boolean              @default(true)
  note        String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  locations   InventoryLocation[]
  racks       WarehouseRack[]
  warehouse   Warehouse            @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, code])
  @@index([warehouseId, isActive])
  @@map("warehouse_zones")
}

model WarehouseRack {
  id        Int            @id @default(autoincrement())
  zoneId    Int
  code      String         @db.VarChar(64)
  name      String         @db.VarChar(200)
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)
  note      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  bins      WarehouseBin[]
  zone      WarehouseZone  @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, code])
  @@index([zoneId, isActive])
  @@map("warehouse_racks")
}

model WarehouseBin {
  id            Int                 @id @default(autoincrement())
  rackId        Int
  code          String              @db.VarChar(64)
  name          String              @db.VarChar(200)
  sortOrder     Int                 @default(0)
  isActive      Boolean             @default(true)
  note          String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  /// Wave-2 putaway: soft capacity limit (units); null = unlimited
  maxUnits      Int?
  allowMixedSku Boolean             @default(true)
  storageClass  String?             @db.VarChar(32)
  locations     InventoryLocation[]
  rack          WarehouseRack       @relation(fields: [rackId], references: [id], onDelete: Cascade)

  @@unique([rackId, code])
  @@index([rackId, isActive])
  @@map("warehouse_bins")
}

model Campaign {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?

  // Campaign Period
  startDate DateTime
  endDate   DateTime
  bookingStartAt DateTime?
  bookingEndAt   DateTime?

  // Configuration
  status     CampaignStatus     @default(DRAFT)
  visibility CampaignVisibility @default(PUBLIC)
  countdownEnabled Boolean @default(false)

  // Pricing
  pricingType CampaignPricingType @default(FREE)
  priceAmount Decimal?            @db.Decimal(10, 2)
  vaccineCost   Decimal?          @db.Decimal(10, 2)
  serviceCharge Decimal?          @db.Decimal(10, 2)
  packageFeatures Json            @default("[]")
  currency    String              @default("BDT")

  // Settings
  maxPetsPerBooking  Int     @default(5)
  advanceBookingDays Int     @default(30)
  minAdvanceHours    Int     @default(24)
  allowWalkIns       Boolean @default(true)
  walkInQuotaPercent Int     @default(20)

  // Target
  targetVaccinations Int @default(0)

  // Metadata
  organizerId  Int?
  organizer    Organization? @relation("CampaignOrganizer", fields: [organizerId], references: [id])
  metadataJson Json?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  // Relations
  locations         CampaignLocation[]
  vaccineTypes      CampaignVaccineType[]
  includedVaccines  CampaignIncludedVaccine[]
  bookings     CampaignBooking[]
  staff        CampaignStaff[]
  smsTemplates CampaignSmsTemplate[]
  auditLogs    CampaignAuditLog[]
  rolloutPhases      CampaignRolloutPhase[]
  rolloutRegions     CampaignRolloutRegion[]
  preRegistrations   CampaignPreRegistration[]
  checkoutSessions   CampaignCheckoutSession[]
  config             CampaignConfig?

  @@index([status])
  @@index([startDate, endDate])
  @@index([bookingStartAt, bookingEndAt])
  @@index([slug])
  @@map("campaigns")
}

model CampaignConfig {
  id         Int @id @default(autoincrement())
  campaignId Int @unique
  version    Int @default(1)

  // Booking & Capacity
  bookingEnabled     Boolean @default(true)
  walkInAllowed      Boolean @default(true)
  approvalRequired   Boolean @default(false)
  slotRequired       Boolean @default(true)
  autoCloseWhenFull  Boolean @default(true)
  maxCapacity        Int     @default(0)
  maxCatsPerBooking  Int     @default(5)
  showRemainingSlots Boolean @default(true)
  lateBookingAllowed Boolean @default(false)

  // Payment
  onlinePaymentEnabled Boolean @default(false)
  payAtVenueEnabled    Boolean @default(false)
  paymentChannelMode   CampaignPaymentChannelMode @default(SMS_ONLY) @map("payment_channel_mode")

  // Advanced (JSON)
  metadataJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_configs")
}

model CampaignConfigHistory {
  id           Int      @id @default(autoincrement())
  campaignId   Int
  version      Int
  changedBy    Int?
  changeReason String?
  configJson   Json
  createdAt    DateTime @default(now())

  @@index([campaignId, version])
  @@map("campaign_config_history")
}

model CampaignLocation {
  id          Int     @id @default(autoincrement())
  campaignId  Int
  name        String
  address     String?
  addressJson Json? // Structured: { division, district, upazila, area }

  // Geolocation
  latitude  Float?
  longitude Float?

  // Contact
  contactName  String?
  contactPhone String?

  // Capacity
  dailyCapacity Int @default(100)

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  campaign Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  slots    CampaignSlot[]
  bookings         CampaignBooking[]
  staff            CampaignStaff[]
