  breed        Breed?          @relation("CampaignPetBreed", fields: [breedId], references: [id])
  permanentPet Pet?            @relation("CampaignPetPermanent", fields: [permanentPetId], references: [id])
  vaccination  Vaccination?    @relation("CampaignPetVaccination", fields: [vaccinationId], references: [id])

  @@index([bookingId])
  @@index([permanentPetId])
  @@index([vaccinationStatus])
  @@map("campaign_pets")
}

model CampaignStaff {
