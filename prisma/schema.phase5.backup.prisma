  coatPattern              CoatPattern?          @relation(fields: [coatPatternId], references: [id])
  color                    AnimalColor?          @relation(fields: [colorId], references: [id])
  profilePic               Media?                @relation("PetProfilePic", fields: [profilePicId], references: [id])
  size                     AnimalSize?           @relation(fields: [sizeId], references: [id])
  subBreed                 SubBreed?             @relation(fields: [subBreedId], references: [id])
  user                     User                  @relation(fields: [userId], references: [id])
  prescriptions            Prescription[]
  surgeryCases             SurgeryCase[]
  vaccinations             Vaccination[]
  vaccinationReminders     VaccinationReminder[]
