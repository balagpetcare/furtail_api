  fromStatus  VerificationStatus?
  toStatus    VerificationStatus?
  adminUserId Int?
  note        String?
  createdAt   DateTime               @default(now())
  adminUser   User?                  @relation("VerificationLogAdmin", fields: [adminUserId], references: [id])

  @@index([entityType, entityId])
  @@index([adminUserId])
  @@map("verification_logs")
}

model VerificationCase {
  id                Int                     @id @default(autoincrement())
  entityType        VerificationEntityType
  entityId          Int
  status            VerificationCaseStatus  @default(DRAFT)
  submittedAt       DateTime?
  reviewedAt        DateTime?
  reviewedByAdminId Int?
  reviewSummary     String?
  lockReason        String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  isLocked          Boolean                 @default(false)
  /// V2: Owner/Org/Branch draft data snapshot (non-breaking add-only)
  /// This keeps Flutter/public APIs untouched while Owner Panel uses a unified verification case payload.
  payloadJson       Json?
  events            VerificationCaseEvent[]
  reviewedByAdmin   User?                   @relation("VerificationCaseReviewedBy", fields: [reviewedByAdminId], references: [id])
  documents         VerificationDocument[]

  @@index([entityType, entityId])
  @@index([status])
  @@index([reviewedByAdminId])
  @@map("verification_cases")
}

model VerificationDocument {
  id               Int                   @id @default(autoincrement())
  caseId           Int
  docType          DocumentType
  status           VerificationDocStatus @default(PENDING)
  isRequired       Boolean               @default(true)
  mediaId          Int
  version          Int                   @default(1)
  docNumber        String?
  issueDate        DateTime?
  expiryDate       DateTime?
  rejectReason     String?
  instruction      String?
  checkedAt        DateTime?
  checkedByAdminId Int?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  verificationCase VerificationCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  checkedByAdmin   User?                 @relation("VerificationDocCheckedBy", fields: [checkedByAdminId], references: [id])
  media            Media                 @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([docType])
  @@index([status])
  @@index([checkedByAdminId])
  @@map("verification_documents")
}

model VerificationCaseEvent {
  id               Int                     @id @default(autoincrement())
  caseId           Int
  action           VerificationAction
  from             VerificationCaseStatus?
  to               VerificationCaseStatus?
  actorAdminId     Int?
  note             String?
  createdAt        DateTime                @default(now())
  actorAdmin       User?                   @relation("VerificationCaseEventAdmin", fields: [actorAdminId], references: [id])
  verificationCase VerificationCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([actorAdminId])
  @@map("verification_case_events")
}

model Notification {
  id                   Int                             @id @default(autoincrement())
  userId               Int
  type                 NotificationType
  title                String
  message              String
  meta                 Json?
  readAt               DateTime?
  createdAt            DateTime                        @default(now())
  priority             NotificationPriority            @default(P2)
  status               NotificationStatus              @default(ACTIVE)
  actionUrl            String?                         @db.VarChar(1024)
  dedupeKey            String?                         @db.VarChar(255)
  expiresAt            DateTime?
  recipientScopeType   NotificationRecipientScopeType?
  recipientScopeId     String?                         @db.VarChar(255)
  orgId                Int?
  branchId             Int?
  severity             String?                         @db.VarChar(32)
  source               String?                         @db.VarChar(64)
  senderId             Int?
  deliveries           NotificationDelivery[]
  reads                NotificationRead[]
  vaccinationReminders VaccinationReminder[]
  sender               User?                           @relation("NotificationSender", fields: [senderId], references: [id])
  user                 User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
  @@index([dedupeKey])
  @@index([orgId])
  @@index([branchId])
  @@map("notifications")
}

model NotificationRead {
  id             Int          @id @default(autoincrement())
  notificationId Int
  userId         Int
  readAt         DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
