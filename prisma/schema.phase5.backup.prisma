// National phased rollout (division → district → city/upazila → venue)
model CampaignRolloutPhase {
  id                 Int                        @id @default(autoincrement())
  campaignId         Int
  phaseCode          CampaignRolloutPhaseCode
  name               String
  description        String?
  status             CampaignRolloutPhaseStatus @default(PLANNED)
  sortOrder          Int                        @default(0)
  nationwideGoalPets Int                        @default(10000)
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  campaign Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  regions  CampaignRolloutRegion[]

  @@unique([campaignId, phaseCode])
  @@index([campaignId, status])
  @@map("campaign_rollout_phases")
}

model CampaignRolloutRegion {
  id             Int      @id @default(autoincrement())
  phaseId        Int
  campaignId     Int
  divisionId     Int?
  districtId     Int?
  upazilaId      Int?
  city           String?
  venueName      String?
  venueAddress   String?
  locationId     Int?
  startDate      DateTime?
  endDate        DateTime?
  targetCapacity Int      @default(0)
  bookedCount    Int      @default(0)
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  phase            CampaignRolloutPhase      @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  campaign         Campaign                  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location         CampaignLocation?         @relation(fields: [locationId], references: [id], onDelete: SetNull)
  preRegistrations CampaignPreRegistration[]
  checkoutSessions CampaignCheckoutSession[]
  bookings         CampaignBooking[]

  @@index([campaignId, isActive])
  @@index([phaseId])
  @@index([divisionId, districtId, upazilaId])
  @@map("campaign_rollout_regions")
}

model CampaignPreRegistration {
  id         Int                           @id @default(autoincrement())
