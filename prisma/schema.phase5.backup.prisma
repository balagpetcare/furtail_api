generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model AnimalCategory {
  id           Int          @id @default(autoincrement())
  code         String       @unique
  name         String
  displayOrder Int          @default(0)
  isActive     Boolean      @default(true)
  animalTypes  AnimalType[]

  @@map("animal_categories")
}

model AnimalType {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  categoryId     Int?
  code           String?         @unique
  scientificName String?         @db.VarChar(128)
  icon           String?         @db.VarChar(64)
  displayOrder   Int?            @default(0)
  isActive       Boolean?        @default(true)
  category       AnimalCategory? @relation(fields: [categoryId], references: [id])
  breeds         Breed[]
  pets           Pet[]
  vaccineTypes   VaccineType[]
  // Campaign 2026 relations
  campaignPets   CampaignPet[]   @relation("CampaignPetAnimalType")

  @@map("animal_types")
}

model AnimalSize {
  id            Int     @id @default(autoincrement())
  code          String  @unique
  name          String
  minWeightKg   Float?
  maxWeightKg   Float?
  displayOrder  Int     @default(0)
  isActive      Boolean @default(true)
  breedsDefault Breed[]
  pets          Pet[]

  @@map("animal_sizes")
}

model AnimalColor {
  id           Int     @id @default(autoincrement())
  code         String  @unique
  name         String
  hexPreview   String? @db.VarChar(16)
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  pets         Pet[]

  @@map("animal_colors")
}

model CoatPattern {
  id           Int     @id @default(autoincrement())
  code         String  @unique
  name         String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  pets         Pet[]

  @@map("coat_patterns")
}

model Breed {
  id            Int           @id @default(autoincrement())
  name          String
  animalTypeId  Int
  code          String?       @db.VarChar(64)
  aliasNames    Json?
  originCountry String?       @db.VarChar(64)
  defaultSizeId Int?
  isMixed       Boolean       @default(false)
  isOther       Boolean       @default(false)
  displayOrder  Int?          @default(0)
  isActive      Boolean?      @default(true)
  animalType    AnimalType    @relation(fields: [animalTypeId], references: [id])
  defaultSize   AnimalSize?   @relation(fields: [defaultSizeId], references: [id])
  pets          Pet[]
  subBreeds     SubBreed[]
  // Campaign 2026 relations
  campaignPets  CampaignPet[] @relation("CampaignPetBreed")

  @@unique([name, animalTypeId])
  @@map("breeds")
}

model SubBreed {
  id           Int     @id @default(autoincrement())
  breedId      Int
  code         String  @db.VarChar(64)
  name         String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  pets         Pet[]
  breed        Breed   @relation(fields: [breedId], references: [id])

  @@unique([breedId, code])
  @@map("sub_breeds")
}

model UserAuth {
  id                Int          @id @default(autoincrement())
  userId            Int          @unique
  provider          AuthProvider @default(LOCAL)
  email             String?      @unique
  phone             String?      @unique
  passwordHash      String?
  passwordUpdatedAt DateTime?
  emailVerifiedAt   DateTime?
  phoneVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  failedAttempts    Int          @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  /// OIDC subject (e.g. Google "sub") — set for OAuth-linked accounts
  oauthSubject      String?
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, oauthSubject])
  @@index([email])
  @@index([phone])
  @@index([oauthSubject])
  @@map("user_auth")
}

model UserProfile {
  id                   Int               @id @default(autoincrement())
  userId               Int               @unique
  displayName          String
  username             String            @unique
  bio                  String?
  visibility           ProfileVisibility @default(PUBLIC)
  showEmail            Boolean           @default(false)
  showPhone            Boolean           @default(false)
  avatarMediaId        Int?
  coverMediaId         Int?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  /// Self-service optional personal fields (enterprise profile hub)
  gender               Gender?
  dateOfBirth          DateTime?
  divisionId           Int?
  districtId           Int?
  upazilaId            Int?
  unionId              Int?
  areaId               Int?
  addressJson          Json?
  emergencyContactJson Json?
  /// Last OAuth provider snapshot (does not replace manual displayName unless placeholder)
  providerDisplayName  String?           @db.VarChar(256)
  providerAvatarUrl    String?
  providerKey          String?           @db.VarChar(32)
  providerSyncedAt     DateTime?
  avatarMedia          Media?            @relation("UserAvatar", fields: [avatarMediaId], references: [id])
  coverMedia           Media?            @relation("UserCover", fields: [coverMediaId], references: [id])
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([divisionId])
  @@index([districtId])
  @@index([upazilaId])
  @@index([unionId])
  @@index([areaId])
  @@map("user_profiles")
}

model UserStatsCache {
  userId         Int      @id
  followersCount Int      @default(0)
  followingCount Int      @default(0)
  petsCount      Int      @default(0)
  pawPoints      Int      @default(0)
  rankGlobal     Int?
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats_cache")
}

model UserSession {
  id               Int       @id @default(autoincrement())
  userId           Int
  refreshTokenHash String    @unique
  deviceId         String?
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model UserFollow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
  @@map("user_follows")
}

model UserProfileLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  likedById Int
  createdAt DateTime @default(now())
  likedBy   User     @relation("UserProfileLiker", fields: [likedById], references: [id], onDelete: Cascade)
  user      User     @relation("UserProfileLiked", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, likedById])
  @@index([userId])
  @@index([likedById])
  @@map("user_profile_likes")
}

model UserFriendRequest {
  id         Int                 @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  fromUser   User                @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User                @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId])
  @@map("user_friend_requests")
}

model UserFriend {
  id        Int      @id @default(autoincrement())
  userAId   Int
  userBId   Int
  createdAt DateTime @default(now())
  userA     User     @relation("UserFriendA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("UserFriendB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@map("user_friends")
}

model Achievement {
  id             Int               @id @default(autoincrement())
  code           String            @unique
  title          String
  description    String?
  requiredPoints Int               @default(0)
  pointsReward   Int               @default(0)
  howTo          String?
  iconMediaId    Int?
  createdAt      DateTime          @default(now())
  iconMedia      Media?            @relation("AchievementIcon", fields: [iconMediaId], references: [id])
  users          UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            Int         @id @default(autoincrement())
  userId        Int
  achievementId Int
  unlockedAt    DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model UserGalleryItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  mediaId   Int
  caption   String?
  createdAt DateTime @default(now())
  deleted   Boolean  @default(false)
  media     Media    @relation("UserGalleryMedia", fields: [mediaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_gallery_items")
}

