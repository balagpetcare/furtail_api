  updatedAt               DateTime               @updatedAt
  code                    String?
  phone                   String?
  email                   String?
  addressLine1            String?
  addressLine2            String?
  district                String?
  city                    String?
  country                 String?
  vendorType              VendorType?            @default(OTHER)
  defaultPaymentTermsDays Int?
