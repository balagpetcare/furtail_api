model Place {
  id                    Int      @id @default(autoincrement())
  latitude              Float
  longitude             Float
  countryCode           String?
  stateName             String?
  cityName              String?
  formattedAddress      String?  @db.VarChar(1024)
  rawAddressJson        Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  usersWithCurrentPlace User[]

  @@index([latitude, longitude])
  @@map("places")
}

model LocationPlace {
  id                            Int                   @id @default(autoincrement())
  countryCode                   String
  admin1                        String?
  admin2                        String?
  city                          String?
  postalCode                    String?
  formattedAddress              String?               @db.VarChar(1024)
  lat                           Float?
  lng                           Float?
  geoHash                       String?
  source                        LocationSource?
  sourcePlaceId                 String?
