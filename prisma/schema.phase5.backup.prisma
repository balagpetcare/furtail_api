// ============================================================================
// Campaign Management System for mass vaccination events
// Reuses existing: User, Pet, VaccineType, Vaccination, Order, Notification
// ============================================================================

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CampaignVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum CampaignPricingType {
  FREE
  PAID
  DONATION
}

enum CampaignSlotStatus {
  OPEN
  FULL
  CLOSED
  CANCELLED
}

enum CampaignBookingStatus {
  DRAFT
  PENDING_ASSIGNMENT
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum CampaignBookingMode {
  VENUE
  ZONE_INTEREST
}

enum CampaignPaymentStatus {
  NOT_REQUIRED
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum CampaignRefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CampaignPetVaccinationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DEFERRED
  SKIPPED
}

enum CampaignStaffRole {
  ADMIN
  COORDINATOR
  CHECK_IN
  VACCINATOR
  SUPPORT
}

enum CampaignSmsStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
}

enum CampaignRolloutPhaseStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum CampaignRolloutPhaseCode {
  PHASE_1
  PHASE_2
  PHASE_3
  PHASE_4
}

enum CampaignPaymentChannelMode {
  SMS_ONLY
  EPS_ONLY
  SMS_AND_EPS
  EPS_WITH_SMS_FALLBACK
}

enum CampaignPreRegistrationStatus {
  WAITING
  NOTIFIED
  CONVERTED
  CANCELLED
}

model Campaign {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?

  // Campaign Period
  startDate DateTime
  endDate   DateTime
  bookingStartAt DateTime?
  bookingEndAt   DateTime?

  // Configuration
  status     CampaignStatus     @default(DRAFT)
  visibility CampaignVisibility @default(PUBLIC)
  countdownEnabled Boolean @default(false)

  // Pricing
  pricingType CampaignPricingType @default(FREE)
  priceAmount Decimal?            @db.Decimal(10, 2)
  vaccineCost   Decimal?          @db.Decimal(10, 2)
  serviceCharge Decimal?          @db.Decimal(10, 2)
  packageFeatures Json            @default("[]")
  currency    String              @default("BDT")

  // Settings
  maxPetsPerBooking  Int     @default(5)
  advanceBookingDays Int     @default(30)
  minAdvanceHours    Int     @default(24)
  allowWalkIns       Boolean @default(true)
  walkInQuotaPercent Int     @default(20)

  // Target
  targetVaccinations Int @default(0)

  // Metadata
  organizerId  Int?
  organizer    Organization? @relation("CampaignOrganizer", fields: [organizerId], references: [id])
  metadataJson Json?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  // Relations
  locations         CampaignLocation[]
  vaccineTypes      CampaignVaccineType[]
  includedVaccines  CampaignIncludedVaccine[]
  bookings     CampaignBooking[]
  staff        CampaignStaff[]
  smsTemplates CampaignSmsTemplate[]
  auditLogs    CampaignAuditLog[]
  rolloutPhases      CampaignRolloutPhase[]
  rolloutRegions     CampaignRolloutRegion[]
  preRegistrations   CampaignPreRegistration[]
  checkoutSessions   CampaignCheckoutSession[]
  config             CampaignConfig?

  @@index([status])
  @@index([startDate, endDate])
  @@index([bookingStartAt, bookingEndAt])
  @@index([slug])
  @@map("campaigns")
}

model CampaignConfig {
  id         Int @id @default(autoincrement())
  campaignId Int @unique
  version    Int @default(1)

  // Booking & Capacity
  bookingEnabled     Boolean @default(true)
  walkInAllowed      Boolean @default(true)
  approvalRequired   Boolean @default(false)
  slotRequired       Boolean @default(true)
  autoCloseWhenFull  Boolean @default(true)
  maxCapacity        Int     @default(0)
  maxCatsPerBooking  Int     @default(5)
  showRemainingSlots Boolean @default(true)
  lateBookingAllowed Boolean @default(false)

  // Payment
  onlinePaymentEnabled Boolean @default(false)
  payAtVenueEnabled    Boolean @default(false)
  paymentChannelMode   CampaignPaymentChannelMode @default(SMS_ONLY) @map("payment_channel_mode")

  // Advanced (JSON)
  metadataJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_configs")
}

model CampaignConfigHistory {
  id           Int      @id @default(autoincrement())
  campaignId   Int
  version      Int
  changedBy    Int?
  changeReason String?
  configJson   Json
  createdAt    DateTime @default(now())

  @@index([campaignId, version])
  @@map("campaign_config_history")
}

model CampaignLocation {
  id          Int     @id @default(autoincrement())
  campaignId  Int
  name        String
  address     String?
  addressJson Json? // Structured: { division, district, upazila, area }

  // Geolocation
  latitude  Float?
  longitude Float?

  // Contact
  contactName  String?
  contactPhone String?

  // Capacity
  dailyCapacity Int @default(100)

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  campaign Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  slots    CampaignSlot[]
  bookings         CampaignBooking[]
  staff            CampaignStaff[]
  rolloutRegions   CampaignRolloutRegion[]

  @@index([campaignId])
  @@index([isActive])
  @@map("campaign_locations")
}

model CampaignSlot {
  id         Int @id @default(autoincrement())
  locationId Int

  // Schedule
  date      DateTime @db.Date
  startTime String   @db.VarChar(5) // "09:00"
  endTime   String   @db.VarChar(5) // "12:00"

  // Session (optional — legacy rows use API inference)
  sessionName        String? @db.VarChar(120)
  checkInStartTime   String? @db.VarChar(5)
  bookingCutoffTime  String? @db.VarChar(5)

  // Capacity
  capacity    Int @default(50)
  bookedCount Int @default(0)
  walkInCount Int @default(0)

  // Status
  status CampaignSlotStatus @default(OPEN)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  location CampaignLocation  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  bookings CampaignBooking[]

  @@unique([locationId, date, startTime])
  @@index([locationId, date])
  @@index([status])
  @@map("campaign_slots")
}

model CampaignVaccineType {
  id            Int @id @default(autoincrement())
  campaignId    Int
  vaccineTypeId Int

  // Pricing Override (if different from campaign)
  priceOverride Decimal? @db.Decimal(10, 2)

  // Stock (optional tracking)
  allocatedDoses Int?
  usedDoses      Int  @default(0)

  // Status
  isActive Boolean @default(true)

  // Relations
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  vaccineType VaccineType @relation(fields: [vaccineTypeId], references: [id])

  @@unique([campaignId, vaccineTypeId])
  @@map("campaign_vaccine_types")
}

/// Branded vaccine information for public campaign pages (name, diseases, display order).
model CampaignIncludedVaccine {
  id              Int      @id @default(autoincrement())
  campaignId      Int
  name            String
  description     String?
  coveredDiseases Json     @default("[]")
  displayOrder    Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, displayOrder])
  @@map("campaign_included_vaccines")
}

model CampaignBooking {
  id Int @id @default(autoincrement())

  // Reference
  bookingRef String @unique @db.VarChar(12) // e.g., "VAC-ABC123"
  qrToken    String @unique @db.VarChar(32)

  // Campaign Link
  campaignId Int
  locationId Int?
  slotId     Int?
  bookingMode CampaignBookingMode @default(VENUE)

  // Owner (may or may not have BPA account)
  ownerUserId      Int? // NULL if not linked to BPA account
  ownerPhone       String @db.VarChar(15)
  ownerName        String
  ownerAddressJson Json?

  // Booking Details
  bookingDate DateTime @db.Date
  petCount    Int      @default(1)

  // Status
  status CampaignBookingStatus @default(CONFIRMED)

  // Check-in
  checkedInAt       DateTime?
  checkedInByUserId Int?
  queueNumber       String?   @db.VarChar(10)

  // Completion
  completedAt DateTime?

  // Walk-in flag
  isWalkIn Boolean @default(false)

  // Payment
  paymentStatus  CampaignPaymentStatus @default(NOT_REQUIRED)
  paymentOrderId Int? // Link to existing Order model
  paidAmount     Decimal?              @db.Decimal(10, 2)

  // Cancellation
  cancelledAt  DateTime?
  cancelReason String?
  refundStatus CampaignRefundStatus?
  refundAmount Decimal?              @db.Decimal(10, 2)

  // Linking
  linkSource String?   @db.VarChar(32)
  linkedAt   DateTime?

  // Simplified booking (2026 express flow)
  rolloutRegionId     Int?
  coverageZoneId      Int?
  coverageZoneName    String? @db.VarChar(200)
  bdAreaId            Int?
  bookingArea         String? @db.VarChar(200)
  checkoutSessionId   String? @unique @db.VarChar(32)
  ownerAlternatePhone String? @db.VarChar(15)

  // Metadata
  metadataJson Json?

  // Post-payment confirmation SMS (idempotent dispatch)
  smsSentAt    DateTime?
  smsReference String?   @db.VarChar(64)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  campaign        Campaign                 @relation(fields: [campaignId], references: [id])
  location        CampaignLocation?        @relation(fields: [locationId], references: [id])
  slot            CampaignSlot?            @relation(fields: [slotId], references: [id])
  rolloutRegion   CampaignRolloutRegion?   @relation(fields: [rolloutRegionId], references: [id], onDelete: SetNull)
  coverageZone    CoverageZone?            @relation(fields: [coverageZoneId], references: [id], onDelete: SetNull)
  bdArea          BdArea?                  @relation(fields: [bdAreaId], references: [id], onDelete: SetNull)
  checkoutSession CampaignCheckoutSession? @relation(fields: [checkoutSessionId], references: [id], onDelete: SetNull)
  owner           User?                    @relation("CampaignBookingOwner", fields: [ownerUserId], references: [id])
  checkedInBy     User?                    @relation("CampaignBookingCheckedInBy", fields: [checkedInByUserId], references: [id])
  paymentOrder    Order?                   @relation("CampaignBookingPaymentOrder", fields: [paymentOrderId], references: [id])
  pets                CampaignPet[]
  smsLogs             CampaignSmsLog[]
  vaccinations        Vaccination[]            @relation("CampaignVaccinations")
  paymentTransactions PaymentTransaction[]

  @@index([campaignId, bookingDate])
  @@index([rolloutRegionId])
  @@index([coverageZoneId])
  @@index([bdAreaId])
  @@index([bookingMode])
  @@index([ownerPhone])
  @@index([slotId, status])
  @@index([qrToken])
  @@index([bookingRef])
  @@index([status, bookingDate])
  @@map("campaign_bookings")
}

model CampaignPet {
  id        Int @id @default(autoincrement())
  bookingId Int

  // Pet Details
  name             String
  animalTypeId     Int     @default(2) // Default: Cat
  breedId          Int?
  gender           Gender?
  ageMonths        Int? // Approximate age in months
  colorDescription String?

  // Link to permanent Pet record (after vaccination)
  permanentPetId Int?

  // Vaccination Status
  vaccinationStatus CampaignPetVaccinationStatus @default(PENDING)
  vaccinationId     Int?                         @unique // Link to Vaccination record after done

  // Per-cat vaccination ticket (QR scan on campaign day)
  ticketToken    String?   @unique @db.VarChar(32)
  ticketIssuedAt DateTime?

  // Certificate
  certificateToken       String?   @unique @db.VarChar(20)
  certificateGeneratedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  booking      CampaignBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  animalType   AnimalType      @relation("CampaignPetAnimalType", fields: [animalTypeId], references: [id])
  breed        Breed?          @relation("CampaignPetBreed", fields: [breedId], references: [id])
  permanentPet Pet?            @relation("CampaignPetPermanent", fields: [permanentPetId], references: [id])
  vaccination  Vaccination?    @relation("CampaignPetVaccination", fields: [vaccinationId], references: [id])

  @@index([bookingId])
  @@index([permanentPetId])
  @@index([vaccinationStatus])
  @@map("campaign_pets")
}

model CampaignStaff {
  id         Int  @id @default(autoincrement())
  campaignId Int
  locationId Int? // NULL = all locations
  userId     Int

  // Role
  role CampaignStaffRole

  // Status
  isActive Boolean @default(true)

  // Timestamps
  assignedAt DateTime @default(now())

  // Relations
  campaign Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location CampaignLocation? @relation(fields: [locationId], references: [id])
  user     User              @relation("CampaignStaffUser", fields: [userId], references: [id])

  @@unique([campaignId, locationId, userId])
  @@index([campaignId])
  @@index([userId])
  @@map("campaign_staff")
}

model CampaignSmsTemplate {
  id         Int @id @default(autoincrement())
  campaignId Int

  // Template
  code     String @db.VarChar(50) // e.g., "BOOKING_CONFIRMED"
  template String // With {{placeholders}}

  // Status
  isActive Boolean @default(true)

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, code])
  @@map("campaign_sms_templates")
}

model CampaignSmsLog {
  id         Int  @id @default(autoincrement())
  bookingId  Int?
  campaignId Int

  // Message
  phone        String  @db.VarChar(15)
  templateCode String?
  message      String

  // Status
  status       CampaignSmsStatus @default(QUEUED)
  externalId   String?           @db.VarChar(64) // Gateway message ID
  provider     String?           @db.VarChar(32)
  segmentCount Int?
  estimatedCostBdt Decimal?      @db.Decimal(10, 4)
  errorMessage String?

  // Timestamps
  queuedAt    DateTime  @default(now())
  sentAt      DateTime?
  deliveredAt DateTime?

  // Relations
  booking CampaignBooking? @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([campaignId, status])
  @@index([phone])
  @@map("campaign_sms_logs")
}

enum SmsLogStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
}

model SmsLog {
  id           Int          @id @default(autoincrement())
  phone        String       @db.VarChar(15)
  message      String
  provider     String       @db.VarChar(32)
  status       SmsLogStatus @default(QUEUED)
  response     String?
  template     String?      @db.VarChar(64)
  externalId   String?      @db.VarChar(64)
  errorMessage String?
  attemptCount Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  sentAt       DateTime?

  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("sms_logs")
