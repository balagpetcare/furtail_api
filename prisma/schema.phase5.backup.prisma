  @@unique([orgId, provider, type, externalValue])
  @@index([orgId, provider, type])
  @@map("integration_mappings")
}

model ProductChangeRequest {
  id                    Int                 @id @default(autoincrement())
  orgId                 Int
  type                  ChangeRequestType
  status                ChangeRequestStatus @default(PENDING)
  requestedByUserId     Int
  requestedFromBranchId Int?
  payload               Json
  reviewedByUserId      Int?
  reviewedAt            DateTime?
  note                  String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  org                   Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  requestedBy           User                @relation("ProductCRRequestedBy", fields: [requestedByUserId], references: [id])
  requestedFromBranch   Branch?             @relation("ProductCRFromBranch", fields: [requestedFromBranchId], references: [id])
  reviewedBy            User?               @relation("ProductCRReviewedBy", fields: [reviewedByUserId], references: [id])

  @@index([orgId, status, type])
  @@index([requestedByUserId])
  @@index([requestedFromBranchId])
  @@map("product_change_requests")
}

model StaffInvite {
  id               Int                   @id @default(autoincrement())
  orgId            Int
  branchId         Int?
  divisionId       Int?
  districtId       Int?
  upazilaId        Int?
  unionId          Int?
  areaId           Int?
  role             MemberRole?
  status           StaffInviteStatus     @default(PENDING)
  email            String?
  phone            String?
  displayName      String?
  tokenHash        String                @unique
  expiresAt        DateTime
  invitedByUserId  Int
  acceptedByUserId Int?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  inviteAsDoctor   Boolean               @default(false)
  targetType       StaffInviteTargetType @default(BRANCH)
  warehouseId      Int?
  warehouseRole    WarehouseStaffRole?
  acceptedBy       User?                 @relation("StaffInviteAcceptedBy", fields: [acceptedByUserId], references: [id])
  branch           Branch?               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  invitedBy        User                  @relation("StaffInviteInvitedBy", fields: [invitedByUserId], references: [id])
  org              Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  warehouse        Warehouse?            @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([orgId, targetType, status])
  @@index([branchId, status])
  @@index([divisionId])
  @@index([districtId])
  @@index([upazilaId])
  @@index([unionId])
  @@index([areaId])
  @@index([warehouseId, status])
  @@index([email])
  @@index([phone])
  @@map("staff_invites")
}

model AccessInvite {
  id               Int                @id @default(autoincrement())
  scopeType        AccessInviteScope
  countryId        Int?
  stateId          Int?
  roleId           Int
  status           AccessInviteStatus @default(PENDING)
  email            String
  displayName      String?
  tokenHash        String             @unique
  expiresAt        DateTime
  invitedByUserId  Int
  acceptedByUserId Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  acceptedBy       User?              @relation("AccessInviteAcceptedBy", fields: [acceptedByUserId], references: [id])
  country          Country?           @relation(fields: [countryId], references: [id], onDelete: Cascade)
  invitedBy        User               @relation("AccessInviteInvitedBy", fields: [invitedByUserId], references: [id])
  role             Role               @relation(fields: [roleId], references: [id], onDelete: Cascade)
  state            State?             @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@index([scopeType, status])
  @@index([countryId])
  @@index([stateId])
  @@index([email])
  @@map("access_invites")
}

model Role {
  id                     Int                   @id @default(autoincrement())
  key                    String                @unique
  label                  String
  scope                  RoleScope
  isSystem               Boolean               @default(true)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  accessInvites          AccessInvite[]
  branchMemberRoles      BranchMemberRole[]
  orgMemberRoles         OrgMemberRole[]
  producerStaffRoles     ProducerOrgStaff[]    @relation("ProducerStaffRole")
  producerStaffInvites   ProducerStaffInvite[]
  rolePermissions        RolePermission[]
  countryRoleAssignments UserCountryRole[]
  globalRoleAssignments  UserGlobalRole[]
  stateRoleAssignments   UserStateRole[]

  @@index([scope])
  @@map("roles")
}

model Permission {
  id              Int              @id @default(autoincrement())
  key             String           @unique
  label           String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model OrgMemberRole {
  orgMemberId Int
  roleId      Int
  orgMember   OrgMember @relation(fields: [orgMemberId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([orgMemberId, roleId])
  @@index([roleId])
  @@map("org_member_roles")
}

model BranchMemberRole {
  branchMemberId Int
  roleId         Int
  branchMember   BranchMember @relation(fields: [branchMemberId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([branchMemberId, roleId])
  @@index([roleId])
  @@map("branch_member_roles")
}

model UserGlobalRole {
  userId    Int
  roleId    Int
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_global_roles")
}

model UserCountryRole {
  userId    Int
  countryId Int
  roleId    Int
  createdAt DateTime @default(now())
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, countryId, roleId])
  @@index([countryId])
  @@index([roleId])
  @@map("user_country_roles")
}

model UserStateRole {
  userId    Int
  stateId   Int
  roleId    Int
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, stateId, roleId])
  @@index([stateId])
  @@index([roleId])
  @@map("user_state_roles")
}

model Inventory {
  id           Int                @id @default(autoincrement())
  branchId     Int
  productId    Int
  variantId    Int?
  quantity     Int                @default(0)
  minStock     Int                @default(10)
  expiryDate   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  branch       Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product      Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant?    @relation(fields: [variantId], references: [id])
  transactions StockTransaction[]

  @@index([branchId])
  @@index([productId])
  @@index([variantId])
  @@map("inventory")
}

model StockTransaction {
  id              Int       @id @default(autoincrement())
  inventoryId     Int
  type            String
  quantity        Int
  reason          String?
  createdByUserId Int?
  createdAt       DateTime  @default(now())
  createdBy       User?     @relation("StockTransactionCreatedBy", fields: [createdByUserId], references: [id])
  inventory       Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([createdAt])
  @@map("stock_transactions")
}

model Order {
  id                                Int                             @id @default(autoincrement())
  orderNumber                       String                          @unique
  branchId                          Int
  customerId                        Int?
  status                            OrderStatus                     @default(PENDING)
  totalAmount                       Decimal                         @default(0)
  paymentMethod                     PaymentMethod?
  paymentStatus                     PaymentStatus                   @default(PENDING)
  notes                             String?
  createdByUserId                   Int?
  createdAt                         DateTime                        @default(now())
  updatedAt                         DateTime                        @updatedAt
  fulfilmentInventoryLocationId     Int?
  orderSource                       OrderSource?
  subtotalAmount                    Decimal?                        @db.Decimal(12, 2)
  discountPercent                   Decimal?                        @db.Decimal(5, 2)
  discountAmount                    Decimal?                        @db.Decimal(12, 2)
  taxPercent                        Decimal?                        @db.Decimal(5, 2)
  taxAmount                         Decimal?                        @db.Decimal(12, 2)
  invoiceNumber                     String?                         @unique(where: raw("(\"invoiceNumber\" IS NOT NULL)"))
  posShiftId                        Int?
  visitId                           Int?
  appliedDiscounts                  AppliedDiscount[]
  clinicInvoice                     ClinicInvoice?
  injectionTokens                   InjectionToken[]
  items                             OrderItem[]
  branch                            Branch                          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy                         User?                           @relation("OrderCreatedBy", fields: [createdByUserId], references: [id])
  customer                          User?                           @relation("OrderCustomer", fields: [customerId], references: [id])
  fulfilmentInventoryLocation       InventoryLocation?              @relation("OrderFulfilmentLocation", fields: [fulfilmentInventoryLocationId], references: [id])
  posShift                          PosShift?                       @relation(fields: [posShiftId], references: [id])
  visit                             Visit?                          @relation(fields: [visitId], references: [id])
  posInvoice                        PosInvoice?
  retailDiscountApprovalsConsumed   RetailDiscountApprovalRequest[] @relation("RetailDiscountConsumedOrder")
  serviceDeliveries                 ServiceDelivery[]
  priceResolutionSnapshots          PriceResolutionSnapshot[]
  pricingEmergencyOverridesConsumed PricingEmergencyOverride[]      @relation("PricingEmergencyOverrideConsumed")
  orderPayments                     OrderPayment[]
  // Campaign 2026 relations
  campaignBookings                  CampaignBooking[]               @relation("CampaignBookingPaymentOrder")
  campaignCheckoutSessions          CampaignCheckoutSession[]       @relation("CampaignCheckoutOrder")
  paymentTransactionLogs            PaymentTransactionLog[]

  @@index([branchId])
  @@index([posShiftId])
  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
  @@index([fulfilmentInventoryLocationId])
  @@index([orderSource])
  @@index([visitId])
  @@map("orders")
}

model PosInvoice {
  id            Int       @id @default(autoincrement())
  orderId       Int       @unique
  invoiceNumber String    @unique
  branchId      Int
  subtotal      Decimal   @db.Decimal(12, 2)
  discountPct   Decimal?  @db.Decimal(5, 2)
  discountAmt   Decimal   @default(0) @db.Decimal(12, 2)
  taxPct        Decimal?  @db.Decimal(5, 2)
  taxAmt        Decimal   @default(0) @db.Decimal(12, 2)
  grandTotal    Decimal   @db.Decimal(12, 2)
  paymentMethod String
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  branch        Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("pos_invoices")
}

/// Staff POS draft / held cart (server-side multi-cart). Canonical finalize still creates `Order`.
model PosCart {
  id                      Int                @id @default(autoincrement())
  cartNumber              String             @unique
  branchId                Int
  staffUserId             Int
  posShiftId              Int?
  status                  PosCartStatus      @default(ACTIVE)
  customerUserId          Int?
  ownerDiscountCardId     Int?
  memberNameSnapshot      String?            @db.VarChar(256)
  cardNumberSnapshot      String?            @db.VarChar(32)
  discountPercentSnapshot Decimal?           @db.Decimal(5, 2)
  metadataJson            Json?
  version                 Int                @default(0)
  expiresAt               DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  branch                  Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  staffUser               User               @relation("PosCartStaffUser", fields: [staffUserId], references: [id], onDelete: Restrict)
  posShift                PosShift?          @relation(fields: [posShiftId], references: [id], onDelete: SetNull)
  customer                User?              @relation("PosCartCustomer", fields: [customerUserId], references: [id], onDelete: SetNull)
  ownerDiscountCard       OwnerDiscountCard? @relation(fields: [ownerDiscountCardId], references: [id], onDelete: SetNull)
  lines                   PosCartLine[]

  @@index([branchId, staffUserId, status])
  @@index([branchId])
  @@index([posShiftId])
  @@map("pos_carts")
}

model PosCartLine {
  id                       Int             @id @default(autoincrement())
  cartId                   Int
  productId                Int
  variantId                Int?
  quantity                 Int
  unitListPrice            Decimal         @db.Decimal(12, 2)
  unitSellPrice            Decimal         @db.Decimal(12, 2)
  retailDiscountApprovalId Int?
  pricingSnapshotJson      Json?
  mergedKey                String?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  cart                     PosCart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product                  Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant                  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([cartId])
  @@index([variantId])
  @@map("pos_cart_lines")
}

/// Split-tender payments for an order (POS and future checkout). Sum of PAID rows should match `Order.totalAmount`.
model OrderPayment {
  id            Int                @id @default(autoincrement())
  orderId       Int
  method        PaymentMethod
  amount        Decimal            @db.Decimal(12, 2)
  reference     String?            @db.VarChar(128)
  paymentStatus OrderPaymentStatus @default(PAID)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  order         Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([method])
  @@map("order_payments")
}

/// Audit trail for gateway create / verify / webhook / recovery (Strategy Pattern payments).
model PaymentTransactionLog {
  id             Int      @id @default(autoincrement())
  orderId        Int?
  provider       String   @db.VarChar(32)
  referenceId    String   @db.VarChar(128)
  providerTxId   String?  @db.VarChar(128)
  eventId        String?  @db.VarChar(256)
  phase          String   @db.VarChar(24)
  status         String   @db.VarChar(24)
  amount         Decimal? @db.Decimal(12, 2)
  requestJson    Json?
  responseJson   Json?
  errorMessage   String?
  idempotencyKey String?  @db.VarChar(128)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  order          Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([referenceId])
  @@index([providerTxId])
  @@index([orderId])
  @@index([status, phase, createdAt])
  @@map("payment_transaction_logs")
}

/// Campaign booking payment records (gateway-level transaction log per booking).
model PaymentTransaction {
  id            Int                          @id @default(autoincrement())
  bookingId     Int?
  transactionId String                       @db.VarChar(128)
  gateway       String                       @db.VarChar(32)
  amount        Decimal                      @db.Decimal(10, 2)
  status        PaymentTransactionStatus     @default(PENDING)
  rawResponse   Json?
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  booking       CampaignBooking?             @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([gateway, transactionId])
  @@index([bookingId])
  @@index([status, createdAt])
  @@map("payment_transactions")
}

model OrderItem {
  id                              Int                            @id @default(autoincrement())
  orderId                         Int
  productId                       Int?
  variantId                       Int?
  quantity                        Int
  price                           Decimal
  total                           Decimal
  createdAt                       DateTime                       @default(now())
  serviceId                       Int?
  retailDiscountApprovalRequestId Int?                           @unique
  order                           Order                          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                         Product?                       @relation(fields: [productId], references: [id], onDelete: Restrict)
  retailDiscountApprovalRequest   RetailDiscountApprovalRequest? @relation(fields: [retailDiscountApprovalRequestId], references: [id])
  service                         Service?                       @relation(fields: [serviceId], references: [id])
  variant                         ProductVariant?                @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([serviceId])
  @@map("order_items")
}

model Service {
  id                       Int                       @id @default(autoincrement())
  orgId                    Int
  branchId                 Int
  name                     String
  description              String?
  category                 ServiceCategory
  status                   ServiceStatus             @default(ACTIVE)
  price                    Decimal
  duration                 Int?
  isRecurring              Boolean                   @default(false)
  createdByUserId          Int
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  department               ServiceDepartment         @default(DOCTOR_DESK)
  paymentGateRule          PaymentGateRule           @default(PAY_BEFORE_SERVICE)
  serviceCode              String?                   @unique @db.VarChar(32)
  prerequisiteRule         Json?
  allowDiscount            Boolean                   @default(true)
  maxDiscountPct           Decimal?                  @db.Decimal(5, 2)
  discountNeedsApproval    Boolean                   @default(false)
  taxRuleJson              Json?
  applicableSpecies        Json?
  isCustom                 Boolean                   @default(false)
  proposedByUserId         Int?
  approvalStatus           ServiceApprovalStatus?
  otRequired               Boolean                   @default(false)
  inventoryLinked          Boolean                   @default(false)
  packageAllowed           Boolean                   @default(false)
  specialtyTag             String?                   @db.VarChar(64)
  doctorRequired           Boolean                   @default(true)
  estimatedCostJson        Json?
  allowedRoomTypes         Json?                     @default("[]")
  ownerDiscountEligible    Boolean                   @default(false)
  baseCost                 Decimal?                  @db.Decimal(12, 2)
  minSafePrice             Decimal?                  @db.Decimal(12, 2)
  staffInstructions        String?
  pricingExplanation       String?
  visibleToPublic          Boolean                   @default(true)
  preparationNotes         String?
  aftercareNotes           String?
  faqJson                  Json?
  appointments             Appointment[]
  doctorContractRules      DoctorContractRule[]
  doctorServiceFees        DoctorServiceFee[]
  doctorServiceMappings    DoctorServiceMapping[]
  orderItems               OrderItem[]
  serviceDeliveries        ServiceDelivery[]
  serviceMedia             ServiceMedia[]
  servicePricingChangeLogs ServicePricingChangeLog[]
  pricingVariants          ServicePricingVariant[]
  branch                   Branch                    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy                User                      @relation("ServiceCreatedBy", fields: [createdByUserId], references: [id])
  org                      Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  surgeryCases             SurgeryCase[]
  surgeryPackageTemplates  SurgeryPackageTemplate[]
  surgeryPackages          SurgeryPackage[]

  @@index([orgId, branchId])
  @@index([branchId, status])
  @@index([category])
  @@map("services")
}

model ServicePricingVariant {
  id        Int      @id @default(autoincrement())
  serviceId Int
  species   String   @db.VarChar(32)
  sex       String?  @db.VarChar(16)
  price     Decimal  @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, species, sex])
  @@index([serviceId])
  @@map("service_pricing_variants")
}

/// Links clinic services to uploaded media (hero, gallery, video).
model ServiceMedia {
  id        Int              @id @default(autoincrement())
  serviceId Int
  mediaId   Int
  kind      ServiceMediaKind @default(GALLERY)
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  media     Media            @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  service   Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, sortOrder])
  @@index([mediaId])
  @@map("service_media")
}

/// Append-only audit of branch service pricing / content field changes.
model ServicePricingChangeLog {
  id          Int      @id @default(autoincrement())
  branchId    Int
  serviceId   Int
  actorUserId Int
  beforeJson  Json
  afterJson   Json
  reason      String?  @db.VarChar(512)
  createdAt   DateTime @default(now())
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, createdAt])
  @@index([branchId, createdAt])
  @@map("service_pricing_change_logs")
}

/// Append-only audit of doctor service fee row changes.
/// FK uses ON DELETE SET NULL so history survives row removal (fee row id cleared on parent delete).
model DoctorServiceFeeChangeLog {
  id                 Int               @id @default(autoincrement())
  doctorServiceFeeId Int?
  actorUserId        Int
  beforeJson         Json
  afterJson          Json
  changeReason       String?           @db.VarChar(512)
  createdAt          DateTime          @default(now())
  doctorServiceFee   DoctorServiceFee? @relation(fields: [doctorServiceFeeId], references: [id])

  @@index([doctorServiceFeeId, createdAt])
  @@map("doctor_service_fee_change_logs")
}

model ServiceProposal {
  id               Int               @id @default(autoincrement())
  orgId            Int
  branchId         Int
  title            String            @db.VarChar(128)
  category         ServiceCategory
  department       ServiceDepartment
  suggestedPrice   Decimal?          @db.Decimal(12, 2)
  reason           String?
  status           String            @default("PENDING") @db.VarChar(16)
  proposedByUserId Int
  reviewedByUserId Int?
  reviewedAt       DateTime?
  reviewNote       String?
  createdServiceId Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  branch           Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  org              Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([branchId, status])
  @@map("service_proposals")
}

model ServiceDelivery {
  id                Int       @id @default(autoincrement())
  visitId           Int
  serviceId         Int
  status            String    @db.VarChar(32)
  deliveredAt       DateTime?
  checklistJson     Json?
  consumablesJson   Json?
  notes             String?
  createdAt         DateTime  @default(now())
  orderId           Int?
  paymentVerified   Boolean   @default(false)
  paymentVerifiedAt DateTime?
  verifiedByUserId  Int?
  updatedAt         DateTime  @updatedAt
  order             Order?    @relation(fields: [orderId], references: [id])
  service           Service   @relation(fields: [serviceId], references: [id])
  visit             Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@index([serviceId])
  @@index([orderId])
  @@map("service_deliveries")
}

model Category {
  id             Int                    @id @default(autoincrement())
  parentId       Int?
  name           String
  slug           String
  sortOrder      Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  parent         Category?              @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       Category[]             @relation("CategoryTree")
  masterProducts MasterProductCatalog[]
  products       Product[]

  @@unique([parentId, slug])
  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Brand {
  id             Int                    @id @default(autoincrement())
  name           String
  slug           String                 @unique
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  companyId      Int?
  company        Company?               @relation(fields: [companyId], references: [id])
  masterProducts MasterProductCatalog[]
  products       Product[]

  @@index([slug])
  @@index([companyId])
  @@map("brands")
}

model Company {
  id             Int                    @id @default(autoincrement())
  name           String                 @unique
  country        String?
  website        String?
  description    String?
  isActive       Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  brands         Brand[]
  masterProducts MasterProductCatalog[]

  @@map("companies")
}

model Country {
  id                    Int                    @id @default(autoincrement())
  code                  String                 @unique
  name                  String
  currencyCode          String?                @default("USD")
  timezoneDefault       String?                @default("UTC")
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  latitude              Decimal?               @db.Decimal(10, 8)
  longitude             Decimal?               @db.Decimal(11, 8)
  phoneCode             String?
  controllerOrgId       Int?                   @unique
