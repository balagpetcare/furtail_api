  @@index([orgId, isActive])
  @@map("cost_allocation_policies")
}

/// Optional monthly / period cost drivers (labor hours, facility) for allocation stubs.
model CostDriverInput {
  id              Int          @id @default(autoincrement())
  orgId           Int
  branchId        Int?
  periodStart     DateTime
  periodEnd       DateTime
  laborHours      Decimal?     @db.Decimal(12, 2)
  facilityCost    Decimal?     @db.Decimal(14, 2)
  currency        String       @default("BDT") @db.VarChar(8)
  notes           String?
  createdByUserId Int?
  createdAt       DateTime     @default(now())
  branch          Branch?      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, periodStart])
  @@index([branchId])
  @@map("cost_driver_inputs")
}

/// Atomic derived cost line (explainable; no ledger double-post).
model CostFact {
  id                     Int                   @id @default(autoincrement())
  orgId                  Int
  grain                  FinIntelCostGrain
  component              FinIntelCostComponent
  variantId              Int?
  locationId             Int?
  branchId               Int?
  refType                String                @db.VarChar(64)
  refId                  String                @db.VarChar(64)
  amount                 Decimal               @db.Decimal(16, 4)
  currency               String                @default("BDT") @db.VarChar(8)
  periodStart            DateTime
  periodEnd              DateTime
  inputsJson             Json                  @default("{}")
  methodVersion          Int                   @default(1)
  costAllocationPolicyId Int?
  createdAt              DateTime              @default(now())
  branch                 Branch?               @relation(fields: [branchId], references: [id])
  costAllocationPolicy   CostAllocationPolicy? @relation(fields: [costAllocationPolicyId], references: [id])
  location               InventoryLocation?    @relation(fields: [locationId], references: [id])
  org                    Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  variant                ProductVariant?       @relation(fields: [variantId], references: [id])

  @@index([orgId, periodStart, periodEnd])
  @@index([orgId, variantId])
  @@index([orgId, variantId, branchId, periodStart, periodEnd])
  @@index([refType, refId])
  @@map("cost_facts")
}

/// Roll-up cache: cost-to-serve by variant × branch × period.
model CtsSummary {
  id             Int            @id @default(autoincrement())
  orgId          Int
  branchId       Int
  variantId      Int
  periodStart    DateTime
  periodEnd      DateTime
  totalMaterial  Decimal        @default(0) @db.Decimal(16, 4)
  totalAllocated Decimal        @default(0) @db.Decimal(16, 4)
  unitsBasis     Int?
  unitCts        Decimal?       @db.Decimal(16, 6)
  confidence     Decimal?       @db.Decimal(5, 4)
  methodVersion  Int            @default(1)
  breakdownJson  Json           @default("{}")
  updatedAt      DateTime       @updatedAt
  branch         Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  org            Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([orgId, branchId, variantId, periodStart, periodEnd], map: "cts_summaries_orgId_branchId_variantId_periodStart_periodEnd_ke")
  @@index([orgId, periodStart])
  @@map("cts_summaries")
}

/// Per-org SLO definition (targets are management KPIs, not contractual unless configured).
model ServiceLevelObjective {
  id           Int                  @id @default(autoincrement())
  orgId        Int
  sloKey       String               @db.VarChar(80)
  domain       SloMeasurementDomain
  targetKind   SloTargetKind
  /// Hours for time-based, 0–100 for percent targets, or max breach count — interpret via targetKind
  targetValue  Decimal              @db.Decimal(12, 4)
  windowDays   Int                  @default(7)
  isActive     Boolean              @default(true)
  metaJson     Json                 @default("{}")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  org          Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  measurements SloMeasurement[]

  @@unique([orgId, sloKey])
  @@index([orgId, domain])
  @@map("service_level_objectives")
}

model SloMeasurement {
  id               Int                   @id @default(autoincrement())
  orgId            Int
  sloId            Int
  periodStart      DateTime
  periodEnd        DateTime
  measuredValue    Decimal?              @db.Decimal(14, 6)
  breachCount      Int                   @default(0)
  sampleCount      Int                   @default(0)
  calculationTrace Json                  @default("{}")
  createdAt        DateTime              @default(now())
  org              Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  slo              ServiceLevelObjective @relation(fields: [sloId], references: [id], onDelete: Cascade)

  @@index([orgId, periodStart])
  @@index([sloId])
  @@map("slo_measurements")
}

/// Threshold rules for mapping source signals → unified severity (optional; JSON fallback).
model ExceptionSeverityRule {
  id            Int          @id @default(autoincrement())
  orgId         Int
  exceptionCode String       @db.VarChar(80)
  ruleJson      Json         @default("{}")
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, exceptionCode])
  @@map("exception_severity_rules")
}

/// Unified operational exception inbox (projection; source rows remain canonical).
model OperationalExceptionIndex {
  id               Int                      @id @default(autoincrement())
  orgId            Int
  exceptionCode    String                   @db.VarChar(80)
  title            String                   @db.VarChar(512)
  severity         OpsExceptionSeverity     @default(MEDIUM)
  status           OpsExceptionStatus       @default(OPEN)
  branchId         Int?
  sourceRefType    String                   @db.VarChar(64)
  sourceRefId      String                   @db.VarChar(64)
  openedAt         DateTime                 @default(now())
  dueAt            DateTime?
  assignedToUserId Int?
  acknowledgedAt   DateTime?
  snoozedUntil     DateTime?
  resolvedAt       DateTime?
  resolutionNote   String?
  timelineJson     Json                     @default("[]")
  version          Int                      @default(1)
  breachFlag       Boolean                  @default(false)
  updatedAt        DateTime                 @updatedAt
  assignedTo       User?                    @relation("OpsExceptionAssignee", fields: [assignedToUserId], references: [id])
  branch           Branch?                  @relation(fields: [branchId], references: [id])
  org              Organization             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rca              OperationalExceptionRca?

  @@unique([orgId, sourceRefType, sourceRefId], map: "operational_exception_indices_orgId_sourceRefType_sourceRefId_k")
  @@index([orgId, status, severity])
  @@index([orgId, branchId, openedAt])
  @@index([assignedToUserId])
  @@map("operational_exception_indices")
}

model OperationalExceptionRca {
  id                      Int                       @id @default(autoincrement())
  operationalExceptionId  Int                       @unique
  primaryCause            OpsRcaPrimaryCause        @default(UNKNOWN)
  contributingFactorsJson Json                      @default("[]")
  notes                   String?
  createdByUserId         Int?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  createdBy               User?                     @relation("OpsExceptionRcaAuthor", fields: [createdByUserId], references: [id])
  exception               OperationalExceptionIndex @relation(fields: [operationalExceptionId], references: [id], onDelete: Cascade)

  @@map("operational_exception_rcas")
}

