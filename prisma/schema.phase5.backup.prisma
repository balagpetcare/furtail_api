model AllocationPlan {
  id                      Int                       @id @default(autoincrement())
  orgId                   Int
  stockRequestId          Int?
  medicineRequisitionId   Int?                      @unique
  fromLocationId          Int
  warehouseId             Int?
  status                  AllocationPlanStatus      @default(DRAFT)
  createdByUserId         Int?
  confirmedAt             DateTime?
  cancelledAt             DateTime?
  cancelReason            String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  /// Sum of requisition demand (variants); set after allocation run.
  totalDemandQty          Int?
  /// Sum of line quantityAllocated after allocation.
  totalAllocatedQty       Int?
  /// totalDemandQty - totalAllocatedQty (unmet demand).
  shortageQty             Int?
  /// Optimistic concurrency on confirm/reallocate.
  version                 Int                       @default(0)
  /// AUTO_FEFO | MANUAL | HYBRID | AUTO_FEFO_MULTI
  allocationMethod        String?                   @db.VarChar(32)
  /// SINGLE_SOURCE (default, backward compat) | MULTI_SOURCE
  allocationScope         AllocationScope           @default(SINGLE_SOURCE)
  /// Number of distinct source locations in this plan.
  sourceCount             Int                       @default(1)
  /// Supplementary plan for backorder fulfillment (chain via parentPlanId).
  parentPlanId            Int?                      @unique
  events                  AllocationPlanEvent[]
  lines                   AllocationPlanLine[]
  sourceSummaries         AllocationSourceSummary[]
  backorders              Backorder[]               @relation("BackorderAllocationPlan")
  supplementaryBackorders Backorder[]               @relation("BackorderSupplementaryPlan")
  parentPlan              AllocationPlan?           @relation("SupplementaryPlan", fields: [parentPlanId], references: [id])
  supplementaryPlan       AllocationPlan?           @relation("SupplementaryPlan")
  createdBy               User?                     @relation("AllocationPlanCreatedBy", fields: [createdByUserId], references: [id])
  fromLocation            InventoryLocation         @relation("AllocationPlanFromLocation", fields: [fromLocationId], references: [id])
  medicineRequisition     MedicineRequisition?      @relation(fields: [medicineRequisitionId], references: [id], onDelete: Cascade)
  org                     Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stockRequest            StockRequest?             @relation(fields: [stockRequestId], references: [id], onDelete: Cascade)
  warehouse               Warehouse?                @relation(fields: [warehouseId], references: [id])
  pickLists               PickList[]
  procurementDemandLines  ProcurementDemandLine[]

  @@index([orgId, status])
  @@index([stockRequestId])
  @@map("allocation_plans")
}

/// Audit trail for allocation plan lifecycle (enterprise).
model AllocationPlanEvent {
  id                Int            @id @default(autoincrement())
  orgId             Int
  allocationPlanId  Int
  action            String         @db.VarChar(64)
  fromStatus        String?        @db.VarChar(32)
  toStatus          String?        @db.VarChar(32)
  metadata          Json?
  performedByUserId Int?
  createdAt         DateTime       @default(now())
  allocationPlan    AllocationPlan @relation(fields: [allocationPlanId], references: [id], onDelete: Cascade)
  org               Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  performedBy       User?          @relation("AllocationPlanEventPerformedBy", fields: [performedByUserId], references: [id])

  @@index([orgId])
  @@index([allocationPlanId, createdAt])
  @@map("allocation_plan_events")
}

model AllocationPlanLine {
  id                     Int                     @id @default(autoincrement())
  allocationPlanId       Int
  variantId              Int
  lotId                  Int
  locationId             Int
  quantityAllocated      Int
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  /// Variant-level demand for this wave (set on first lot line per variant when applicable).
  demandQty              Int?
  /// Unmet quantity for this variant on the first line of that variant (0 on subsequent lot lines).
  quantityShort          Int                     @default(0)
  /// ALLOCATED | PARTIAL | SHORT (informational)
  lineStatus             String?                 @db.VarChar(32)
  /// FEFO | MANUAL | FIFO
  allocationMethod       String?                 @db.VarChar(32)
  /// Warehouse that owns this source location (denorm for query convenience).
  sourceWarehouseId      Int?
  allocationPlan         AllocationPlan          @relation(fields: [allocationPlanId], references: [id], onDelete: Cascade)
  location               InventoryLocation       @relation(fields: [locationId], references: [id])
  lot                    StockLot                @relation(fields: [lotId], references: [id])
  sourceWarehouse        Warehouse?              @relation("AllocationLineSourceWarehouse", fields: [sourceWarehouseId], references: [id])
  variant                ProductVariant          @relation(fields: [variantId], references: [id])
  pickListLines          PickListLine[]
  procurementDemandLines ProcurementDemandLine[]

  @@index([allocationPlanId])
  @@index([allocationPlanId, locationId])
  @@index([variantId])
  @@index([lotId])
  @@map("allocation_plan_lines")
}

/// Per-source-location aggregate within a multi-source allocation plan.
model AllocationSourceSummary {
  id                Int                    @id @default(autoincrement())
  orgId             Int
  allocationPlanId  Int
  locationId        Int
  warehouseId       Int?
  totalAllocatedQty Int                    @default(0)
  totalLineCount    Int                    @default(0)
  sourceStatus      AllocationSourceStatus @default(PENDING)
  confirmedAt       DateTime?
  pickListId        Int?                   @unique
  pickCompletedAt   DateTime?
  dispatchId        Int?                   @unique
  dispatchedAt      DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  allocationPlan    AllocationPlan         @relation(fields: [allocationPlanId], references: [id], onDelete: Cascade)
  location          InventoryLocation      @relation("SourceSummaryLocation", fields: [locationId], references: [id])
  warehouse         Warehouse?             @relation("SourceSummaryWarehouse", fields: [warehouseId], references: [id])
  pickList          PickList?              @relation("SourceSummaryPickList", fields: [pickListId], references: [id])
  dispatch          StockDispatch?         @relation("SourceSummaryDispatch", fields: [dispatchId], references: [id])

  @@unique([allocationPlanId, locationId])
  @@index([orgId, sourceStatus])
  @@index([warehouseId, sourceStatus])
  @@map("allocation_source_summaries")
}

/// Persistent record of unmet demand from an allocation plan (drives procurement or supplementary allocation).
model Backorder {
  id                      Int                    @id @default(autoincrement())
  orgId                   Int
  stockRequestId          Int
  stockRequestItemId      Int?
  allocationPlanId        Int
  variantId               Int
  shortageQty             Int
  fulfilledQty            Int                    @default(0)
  remainingQty            Int                    @default(0)
  status                  BackorderStatus        @default(OPEN)
  priority                Int                    @default(0)
  procurementDemandLineId Int?
  supplementaryPlanId     Int?
  notes                   String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  closedAt                DateTime?
  cancelledAt             DateTime?
  allocationPlan          AllocationPlan         @relation("BackorderAllocationPlan", fields: [allocationPlanId], references: [id], onDelete: Cascade)
  org                     Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  procurementDemandLine   ProcurementDemandLine? @relation(fields: [procurementDemandLineId], references: [id])
  stockRequest            StockRequest           @relation(fields: [stockRequestId], references: [id], onDelete: Cascade)
  stockRequestItem        StockRequestItem?      @relation(fields: [stockRequestItemId], references: [id])
  supplementaryPlan       AllocationPlan?        @relation("BackorderSupplementaryPlan", fields: [supplementaryPlanId], references: [id])
  variant                 ProductVariant         @relation(fields: [variantId], references: [id])

  @@index([orgId, status])
  @@index([stockRequestId])
  @@index([variantId, status])
  @@map("backorders")
}

model PickList {
  id                      Int                      @id @default(autoincrement())
  orgId                   Int
  allocationPlanId        Int
  status                  PickListStatus           @default(DRAFT)
  assignedPickerUserId    Int?
  fromLocationId          Int
  stockDispatchId         Int?                     @unique
  startedAt               DateTime?
  completedAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
