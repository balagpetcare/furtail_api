/// Org-level catalog pricing (base + optional markup bounds). Used with pricing engine before LocationPrice.
model ProductPricing {
  id            Int            @id @default(autoincrement())
  orgId         Int
  variantId     Int
  basePrice     Decimal?       @db.Decimal(12, 2)
  markupPercent Decimal?       @db.Decimal(8, 4)
  minPrice      Decimal?       @db.Decimal(12, 2)
  maxPrice      Decimal?       @db.Decimal(12, 2)
  /// Optional regulatory MRP; when set, band validation uses this as the upper cap instead of maxPrice.
  mrp           Decimal?       @db.Decimal(12, 2)
  effectiveFrom DateTime       @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([orgId, variantId])
  @@index([orgId])
  @@index([variantId])
  @@map("product_pricings")
}

/// Branch-level selling price override (optional). Takes precedence over ProductPricing-derived and LocationPrice when effective.
model BranchPricing {
  id            Int            @id @default(autoincrement())
  branchId      Int
  variantId     Int
  overridePrice Decimal        @db.Decimal(12, 2)
  effectiveFrom DateTime       @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([branchId, variantId])
  @@index([branchId])
  @@index([variantId])
  @@map("branch_pricings")
}

/// Org-level switches for pricing governance (central vs branch bounds, retail approval).
model OrgPricingPolicy {
  orgId                                  Int          @id
  enforceBranchOverrideWithinCentralBand Boolean      @default(true)
  retailDiscountApprovalEnabled          Boolean      @default(true)
  createdAt                              DateTime     @default(now())
  updatedAt                              DateTime     @default(now()) @updatedAt
  /// When true, POS commits enforce floor, retail rules, and approval linkage (server-side).
  posPricingGovernanceEnabled            Boolean      @default(false)
  /// When true (and governance is off), barcode / product browse still uses enterprise list resolution for displayed price. When governance is on, enterprise list is always used for scan/browse regardless of this flag.
  posUseEnterpriseListResolution         Boolean      @default(false)
  /// Block checkout unit price below latest GRN reference cost (when cost known).
  blockSaleBelowCost                     Boolean      @default(false)
  /// When true, enforce ProductPricing.minPrice as floor on discounted POS lines.
  blockSaleBelowFloor                    Boolean      @default(true)
  allowCampaignStacking                  Boolean      @default(false)
  allowMembershipStacking                Boolean      @default(false)
  scheduledPricingEnabled                Boolean      @default(false)
  batchPricingEnabled                    Boolean      @default(false)
  defaultMaxDiscountPercent              Decimal?     @db.Decimal(5, 2)
  org                                    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_pricing_policies")
}

